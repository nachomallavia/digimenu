---
/**
 * Guest chrome for `/app/login` and `/app/pending` (no sidebar).
 */
import Root from "./Root.astro";
import { COLOR_MODE_COOKIE, parseColorMode } from "../lib/color-mode";

interface Props {
	title: string;
}

const { title } = Astro.props;
const colorMode = parseColorMode(Astro.cookies.get(COLOR_MODE_COOKIE)?.value);
---

<Root title={title} lang="es" colorMode={colorMode}>
	<main class="mx-auto max-w-xl px-4 py-8">
		<p class="mb-6">
			<a href="/" class="font-semibold text-foreground">DigiMenu</a>
		</p>
		<slot />
	</main>
</Root>
