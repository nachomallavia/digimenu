---
/**
 * Owner DigiMenu panel chrome (`/app/*` authenticated).
 * Always DigiMenu brand — restaurant menu theme does not apply here.
 */
import { ClientRouter, fade } from "astro:transitions";
import Root from "./Root.astro";
import AppSidebar from "../components/app/AppSidebar.astro";
import { Button } from "@/components/starwind/button";
import {
	SidebarInset,
	SidebarProvider,
	SidebarTrigger,
} from "@/components/starwind/sidebar";

interface Props {
	title: string;
	email?: string | null;
	/** URL slug for /m/{slug} */
	restaurantSlug?: string | null;
	/** Display name from EmDash (`nombre`) */
	restaurantName?: string | null;
}

const { title, email, restaurantSlug, restaurantName } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Root title={title} lang="es">
	<ClientRouter slot="head" />

	<SidebarProvider class="min-h-svh">
		<AppSidebar
			currentPath={currentPath}
			restaurantSlug={restaurantSlug}
			restaurantName={restaurantName}
		/>
		<SidebarInset>
			<header
				class="flex h-14 shrink-0 items-center justify-between gap-3 border-b border-border px-4"
			>
				<div class="flex min-w-0 items-center gap-2">
					<SidebarTrigger />
					<div class="min-w-0">
						<p class="truncate text-sm font-medium" data-owner-restaurant-name>
							{restaurantName ?? "Panel"}
						</p>
						{email && <p class="truncate text-xs text-muted-foreground">{email}</p>}
					</div>
				</div>
				<div class="flex shrink-0 items-center gap-2">
					{
						restaurantSlug && (
							<Button
								href={`/m/${restaurantSlug}`}
								variant="outline"
								size="sm"
								target="_blank"
								rel="noopener noreferrer"
								data-astro-reload
							>
								Ver menú
							</Button>
						)
					}
					<form method="POST" action="/app/auth/logout" data-astro-reload>
						<Button type="submit" variant="ghost" size="sm">
							Salir
						</Button>
					</form>
				</div>
			</header>
			<main
				class="flex-1 px-4 py-6 md:px-6"
				transition:animate={fade({ duration: "0.12s" })}
			>
				<slot />
			</main>
		</SidebarInset>
	</SidebarProvider>
</Root>

<style is:global>
	/* Instant swap feel: keep old content visible until new is ready (no blank flash) */
	::view-transition-old(root),
	::view-transition-new(root) {
		animation-duration: 0.12s;
	}
</style>
