---
/**
 * Renders a curated Tabler outline icon by id (categorias.icon).
 * Only the fixed set is imported so the bundle stays small.
 */
import Apple from "@tabler/icons/outline/apple.svg";
import Beer from "@tabler/icons/outline/beer.svg";
import Bottle from "@tabler/icons/outline/bottle.svg";
import Bread from "@tabler/icons/outline/bread.svg";
import Cake from "@tabler/icons/outline/cake.svg";
import Carrot from "@tabler/icons/outline/carrot.svg";
import Coffee from "@tabler/icons/outline/coffee.svg";
import Cup from "@tabler/icons/outline/cup.svg";
import Egg from "@tabler/icons/outline/egg.svg";
import Fish from "@tabler/icons/outline/fish.svg";
import Flame from "@tabler/icons/outline/flame.svg";
import GlassFull from "@tabler/icons/outline/glass-full.svg";
import IceCream from "@tabler/icons/outline/ice-cream.svg";
import Leaf from "@tabler/icons/outline/leaf.svg";
import Meat from "@tabler/icons/outline/meat.svg";
import Pizza from "@tabler/icons/outline/pizza.svg";
import Salad from "@tabler/icons/outline/salad.svg";
import Soup from "@tabler/icons/outline/soup.svg";
import Star from "@tabler/icons/outline/star.svg";
import ToolsKitchen2 from "@tabler/icons/outline/tools-kitchen-2.svg";
import type { CategoryIconId } from "../lib/category-icons";
import { isCategoryIconId } from "../lib/category-icons";

interface Props {
	icon?: string | null;
	class?: string;
	"aria-hidden"?: boolean | "true" | "false";
}

const { icon, class: className = "size-5", ...rest } = Astro.props;
const id = icon && isCategoryIconId(icon) ? (icon as CategoryIconId) : null;

const icons = {
	apple: Apple,
	beer: Beer,
	bottle: Bottle,
	bread: Bread,
	cake: Cake,
	carrot: Carrot,
	coffee: Coffee,
	cup: Cup,
	egg: Egg,
	fish: Fish,
	flame: Flame,
	"glass-full": GlassFull,
	"ice-cream": IceCream,
	leaf: Leaf,
	meat: Meat,
	pizza: Pizza,
	salad: Salad,
	soup: Soup,
	star: Star,
	"tools-kitchen-2": ToolsKitchen2,
} as const;

const Icon = id ? icons[id] : null;
---

{Icon && <Icon class={className} aria-hidden="true" {...rest} />}
