---
/**
 * Owner panel navigation sidebar (DigiMenu brand).
 */
import BuildingStoreIcon from "@tabler/icons/outline/building-store.svg";
import LayoutListIcon from "@tabler/icons/outline/layout-list.svg";
import PaletteIcon from "@tabler/icons/outline/palette.svg";
import TagsIcon from "@tabler/icons/outline/tags.svg";
import PackageIcon from "@tabler/icons/outline/package.svg";
import HomeIcon from "@tabler/icons/outline/home.svg";
import {
	Sidebar,
	SidebarContent,
	SidebarGroup,
	SidebarGroupContent,
	SidebarGroupLabel,
	SidebarHeader,
	SidebarMenu,
	SidebarMenuButton,
	SidebarMenuItem,
	SidebarRail,
	SidebarSeparator,
} from "@/components/starwind/sidebar";

interface Props {
	currentPath: string;
	restaurantSlug?: string | null;
	restaurantName?: string | null;
}

const { currentPath, restaurantSlug, restaurantName } = Astro.props;

const items = [
	{ title: "Resumen", href: "/app", icon: HomeIcon, matchExact: true },
	{ title: "Info restaurante", href: "/app/info", icon: BuildingStoreIcon },
	{ title: "Tipo de menú", href: "/app/menu", icon: LayoutListIcon },
	{ title: "Estilos", href: "/app/estilos", icon: PaletteIcon },
	{ title: "Categorías", href: "/app/categorias", icon: TagsIcon },
	{ title: "Productos", href: "/app/productos", icon: PackageIcon },
];

function isActive(href: string, exact?: boolean) {
	if (exact) return currentPath === href;
	return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<Sidebar collapsible="icon" data-owner-sidebar>
	<SidebarHeader>
		<SidebarMenu>
			<SidebarMenuItem>
				<SidebarMenuButton size="lg" href="/app" tooltip="DigiMenu" data-astro-prefetch="hover">
					<div
						class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-10 items-center justify-center rounded-lg font-semibold"
					>
						D
					</div>
					<div class="grid flex-1 text-left text-sm leading-tight">
						<span class="truncate font-semibold">DigiMenu</span>
						<span
							class="text-sidebar-foreground/70 truncate text-xs"
							data-owner-restaurant-name
						>
							{restaurantName ?? restaurantSlug ?? "Panel"}
						</span>
					</div>
				</SidebarMenuButton>
			</SidebarMenuItem>
		</SidebarMenu>
	</SidebarHeader>

	<SidebarSeparator />

	<SidebarContent>
		<SidebarGroup>
			<SidebarGroupLabel>Menú</SidebarGroupLabel>
			<SidebarGroupContent>
				<SidebarMenu>
					{
						items.map((item) => (
							<SidebarMenuItem>
								<SidebarMenuButton
									href={item.href}
									isActive={isActive(item.href, item.matchExact)}
									tooltip={item.title}
									data-astro-prefetch="hover"
									data-owner-nav={item.href}
									data-owner-nav-exact={item.matchExact ? "1" : undefined}
								>
									<item.icon />
									<span>{item.title}</span>
								</SidebarMenuButton>
							</SidebarMenuItem>
						))
					}
				</SidebarMenu>
			</SidebarGroupContent>
		</SidebarGroup>
	</SidebarContent>

	<SidebarRail />
</Sidebar>

<script>
	function syncOwnerNav() {
		const path = location.pathname;
		document.querySelectorAll<HTMLElement>("[data-owner-nav]").forEach((el) => {
			const href = el.dataset.ownerNav ?? "";
			const exact = el.dataset.ownerNavExact === "1";
			const active = exact ? path === href : path === href || path.startsWith(`${href}/`);
			el.dataset.active = String(active);
		});
	}

	syncOwnerNav();
	document.addEventListener("astro:page-load", syncOwnerNav);
</script>
