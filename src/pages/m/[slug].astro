---
import {
	createEditable,
	getEmDashCollection,
	getEmDashEntry,
} from "emdash";
import Classic from "../../components/menu-templates/Classic.astro";
import Menu from "../../layouts/Menu.astro";
import type {
	EmDashCategoria,
	EmDashMenu,
	EmDashProducto,
	EmDashRestaurante,
	EmDashTag,
} from "../../lib/emdash/client";
import { parseMenuLayout } from "../../lib/menu-layout";
import { parseIdList, productBelongsToMenu } from "../../lib/menu-templates/ids";
import { DEFAULT_MENU_TEMPLATE_ID } from "../../lib/menu-templates/registry";
import { parseRestaurantTheme } from "../../lib/restaurant-theme";

const { slug } = Astro.params;
if (!slug) {
	return Astro.rewrite("/404");
}

const { entry: restauranteRaw, cacheHint: restaurantHint } = await getEmDashEntry(
	"restaurantes",
	slug,
);

if (!restauranteRaw) {
	return Astro.rewrite("/404");
}

const restaurante = restauranteRaw as unknown as EmDashRestaurante & {
	edit?: Record<string, Record<string, unknown>>;
};
const restaurantId = restaurante.data.id;
const layout = parseMenuLayout(
	(restaurante.data as { menu_layout?: unknown }).menu_layout,
);
const theme = parseRestaurantTheme((restaurante.data as { theme?: unknown }).theme);

const [
	productsResult,
	categoriasResult,
	menusResult,
	tagsResult,
] = await Promise.all([
	getEmDashCollection("productos", {
		where: { restaurante: restaurantId },
		limit: 200,
	}),
	getEmDashCollection("categorias", {
		where: { restaurante: restaurantId },
		limit: 100,
	}),
	getEmDashCollection("menus", {
		where: { restaurante: restaurantId },
		limit: 50,
	}),
	getEmDashCollection("tags", {
		where: { restaurante: restaurantId },
		limit: 100,
	}),
]);

const productosRaw = productsResult.error ? [] : productsResult.entries;
const productsHint = productsResult.cacheHint;
const categoriasRaw = categoriasResult.error ? [] : categoriasResult.entries;
const categoriasHint = categoriasResult.cacheHint;
const menusRaw = menusResult.error ? [] : menusResult.entries;
const menusHint = menusResult.cacheHint;
const tagsRaw = tagsResult.error ? [] : tagsResult.entries;
const tagsHint = tagsResult.cacheHint;

const categorias = (categoriasRaw as unknown as EmDashCategoria[])
	.slice()
	.sort((a, b) => {
		const oa = a.data.orden ?? Number.MAX_SAFE_INTEGER;
		const ob = b.data.orden ?? Number.MAX_SAFE_INTEGER;
		if (oa !== ob) return oa - ob;
		return (a.data.nombre ?? "").localeCompare(b.data.nombre ?? "");
	});

const menusListed = (menusRaw as unknown as EmDashMenu[])
	.slice()
	.sort((a, b) => {
		const oa = a.data.orden ?? Number.MAX_SAFE_INTEGER;
		const ob = b.data.orden ?? Number.MAX_SAFE_INTEGER;
		if (oa !== ob) return oa - ob;
		return (a.data.nombre ?? "").localeCompare(b.data.nombre ?? "");
	});

const tags = tagsRaw as unknown as EmDashTag[];

const syntheticMenu: EmDashMenu = {
	id: "_default",
	slug: "carta",
	status: "published",
	data: {
		id: "_default",
		nombre: "Carta",
		descripcion: null,
		restaurante: restaurantId,
		orden: 0,
		plantilla: DEFAULT_MENU_TEMPLATE_ID,
	},
};

const menus = menusListed.length > 0 ? menusListed : [syntheticMenu];

const menuParam = Astro.url.searchParams.get("menu");
const activeMenu =
	(menuParam
		? menus.find((m) => m.slug === menuParam || m.id === menuParam || m.data.id === menuParam)
		: undefined) ?? menus[0];

const soleMenuId = menus.length === 1 ? menus[0].data.id : undefined;

const editor = Astro.locals.user;
const isEditor = !!editor && editor.role >= 30;
const editMode =
	isEditor && Astro.cookies.get("emdash-edit-mode")?.value === "true";

const productosAll = editMode
	? productosRaw.map((entry) => {
			const data = entry.data as {
				id: string;
				status?: string;
				draftRevisionId?: string | null;
				liveRevisionId?: string | null;
			};
			const hasDraft =
				!!data.draftRevisionId && data.draftRevisionId !== data.liveRevisionId;
			return {
				...entry,
				edit: createEditable("productos", data.id, {
					status: data.status ?? "draft",
					hasDraft,
				}),
			};
		})
	: productosRaw;

const productos = (productosAll as unknown as EmDashProducto[]).filter((p) =>
	productBelongsToMenu(p.data.menus, activeMenu.data.id, {
		treatEmptyAsAll: menusListed.length === 0,
		soleMenuId,
	}),
);

const productTagIds = new Map<string, string[]>();
for (const p of productos) {
	productTagIds.set(p.data.id, parseIdList(p.data.tags));
}

if (Astro.cache?.enabled) {
	Astro.cache.set(restaurantHint);
	Astro.cache.set(productsHint);
	Astro.cache.set(categoriasHint);
	if (menusHint) Astro.cache.set(menusHint);
	if (tagsHint) Astro.cache.set(tagsHint);
}
---

<Menu
	title={restaurante.data.nombre}
	description={restaurante.data.descripcion}
	content={{ collection: "restaurantes", id: restaurantId, slug: restaurante.id }}
	restaurantSlug={restaurante.id}
	theme={theme}
>
	<Classic
		restaurant={restaurante}
		menus={menus}
		activeMenu={activeMenu}
		categories={categorias}
		products={productos}
		tags={tags}
		productTagIds={productTagIds}
		theme={theme}
		layout={layout}
	/>
</Menu>
