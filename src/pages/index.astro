---
import { getEmDashCollection, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Menu from "../layouts/Menu.astro";
import { restaurantLogoForMode } from "../lib/restaurant-logo";
import { parseRestaurantTheme } from "../lib/restaurant-theme";
import { resolveStarterSiteIdentity } from "../utils/site-identity";

const { entries: restaurantes, cacheHint } = await getEmDashCollection("restaurantes", {
	orderBy: { created_at: "desc" },
	limit: 50,
});
const { siteTitle, siteTagline } = resolveStarterSiteIdentity(await getSiteSettings());
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Menu title={siteTitle} description={siteTagline}>
	<h1>{siteTitle}</h1>
	{siteTagline && <p>{siteTagline}</p>}

	{
		restaurantes.length === 0 ? (
			<p>
				No hay restaurantes todavía.{" "}
				<a href="/_emdash/admin/content/restaurantes/new">Crear uno</a>.
			</p>
		) : (
			<ul class="restaurant-list">
				{restaurantes.map((r) => {
					const theme = parseRestaurantTheme(
						(r.data as { theme?: unknown }).theme,
					);
					const logo = restaurantLogoForMode(r.data, theme.mode);
					return (
						<li>
							<a href={`/m/${r.id}`}>
								{logo && <Image image={logo} />}
								<span>{r.data.nombre}</span>
							</a>
							{r.data.descripcion && <p>{r.data.descripcion}</p>}
						</li>
					);
				})}
			</ul>
		)
	}
</Menu>

<style>
	.restaurant-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.restaurant-list a {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1.25rem;
	}
	.restaurant-list img {
		height: 2.5rem;
		width: auto;
	}
	.restaurant-list p {
		margin: 0.25rem 0 0;
		opacity: 0.75;
	}
</style>
