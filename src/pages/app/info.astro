---
import Dashboard from "../../layouts/Dashboard.astro";
import { refreshOwnerSnapshot, requireOwner, restaurantSnapshotFromEntry } from "../../lib/auth/require-owner";
import {
	formImageFile,
	imageRefForWrite,
	imageSrc,
	updateRestauranteViaApi,
	uploadMediaViaApi,
	writesEnabled,
	type EmDashRestaurante,
} from "../../lib/emdash/client";
import { loadOwnerRestaurant, savedRedirect } from "../../lib/emdash/owner-restaurant";
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
import { Textarea } from "@/components/starwind/textarea";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/starwind/card";

export const prerender = false;

const auth = await requireOwner(Astro.request, Astro.cookies);
if (!auth.ok) {
	return Astro.redirect(auth.redirect);
}

let owner = auth.owner;
const canWrite = writesEnabled();
let error: string | null = null;
const saved = Astro.url.searchParams.get("saved") === "1";

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const nombre = String(form.get("nombre") ?? "").trim();
	const descripcion = String(form.get("descripcion") ?? "").trim();
	const removeLogoLight = form.get("remove_logo_light") === "1";
	const removeLogoDark = form.get("remove_logo_dark") === "1";
	const logoLightFile = formImageFile(form, "logo_light");
	const logoDarkFile = formImageFile(form, "logo_dark");

	if (!nombre) {
		error = "El nombre es obligatorio.";
	} else if (!canWrite) {
		error = "Escrituras no configuradas (falta EMDASH_API_TOKEN).";
	} else {
		try {
			const update: Record<string, unknown> = {
				nombre,
				descripcion: descripcion || null,
			};

			if (removeLogoLight) {
				update.logo_light = null;
			} else if (logoLightFile) {
				const uploaded = await uploadMediaViaApi(logoLightFile, `${nombre} (claro)`);
				update.logo_light = imageRefForWrite(uploaded);
			}

			if (removeLogoDark) {
				update.logo_dark = null;
			} else if (logoDarkFile) {
				const uploaded = await uploadMediaViaApi(logoDarkFile, `${nombre} (oscuro)`);
				update.logo_dark = imageRefForWrite(uploaded);
			}

			const updated = await updateRestauranteViaApi(
				owner.restaurant.emdash_restaurant_id,
				update,
			);
			const data = updated.item.data;
			const entryForSnap = {
				id: owner.restaurant.emdash_restaurant_slug,
				slug: owner.restaurant.emdash_restaurant_slug,
				status: "published",
				data: {
					id: owner.restaurant.emdash_restaurant_id,
					nombre: typeof data.nombre === "string" ? data.nombre : nombre,
					descripcion:
						typeof data.descripcion === "string"
							? data.descripcion
							: descripcion || undefined,
					menu_layout: data.menu_layout,
					theme: data.theme,
					logo_light: data.logo_light as EmDashRestaurante["data"]["logo_light"],
					logo_dark: data.logo_dark as EmDashRestaurante["data"]["logo_dark"],
				},
			} satisfies EmDashRestaurante;

			await refreshOwnerSnapshot(
				Astro.cookies,
				owner,
				restaurantSnapshotFromEntry(entryForSnap, nombre),
			);
			return Astro.redirect(savedRedirect("/app/info"));
		} catch (err) {
			error = err instanceof Error ? err.message : "No se pudo guardar";
		}
	}
}

// Fresh EmDash read so logo previews match live media (session snapshot can lag).
const restaurant = await loadOwnerRestaurant(owner);
if (!restaurant.entry) {
	error = error ?? "No se encontró el restaurante en EmDash.";
}

const nombre = restaurant.entry?.data.nombre ?? owner.restaurantName;
const descripcion = restaurant.entry?.data.descripcion ?? "";
const logoLightSrc = imageSrc(restaurant.entry?.data.logo_light) ?? null;
const logoDarkSrc = imageSrc(restaurant.entry?.data.logo_dark) ?? null;
---

<Dashboard
	title="DigiMenu — Info"
	email={owner.email}
	restaurantSlug={restaurant.slug}
	restaurantName={restaurant.name}
>
	<div class="mx-auto flex max-w-2xl flex-col gap-6">
		<div>
			<h1 class="text-2xl font-semibold tracking-tight">Info restaurante</h1>
			<p class="text-muted-foreground">
				Nombre, descripción, logos y datos visibles en el menú público.
			</p>
		</div>

		{
			saved && (
				<p class="rounded-md border border-success/30 bg-success/10 px-3 py-2 text-sm text-success-foreground">
					Guardado.
				</p>
			)
		}
		{error && <p class="text-sm text-error">{error}</p>}

		<Card>
			<CardHeader>
				<CardTitle>Datos básicos</CardTitle>
				<CardDescription>Estos datos aparecen en el encabezado del menú público.</CardDescription>
			</CardHeader>
			<CardContent>
				<form method="POST" class="flex flex-col gap-4" enctype="multipart/form-data" data-astro-reload>
					<div class="flex flex-col gap-1.5">
						<Label for="nombre">Nombre</Label>
						<Input id="nombre" name="nombre" required value={nombre} disabled={!canWrite} />
					</div>
					<div class="flex flex-col gap-1.5">
						<Label for="descripcion">Descripción</Label>
						<Textarea
							id="descripcion"
							name="descripcion"
							rows={4}
							disabled={!canWrite}
						>{descripcion}</Textarea>
					</div>
					<div class="grid gap-4 sm:grid-cols-2" data-logo-previews>
						<div class="flex flex-col gap-2">
							<Label for="logo_light">Logo (fondo claro)</Label>
							<img
								data-logo-preview="logo_light"
								src={logoLightSrc ?? ""}
								alt={restaurant.entry?.data.logo_light?.alt ?? `${nombre} (claro)`}
								class:list={[
									"h-20 w-auto max-w-full rounded-md border border-border bg-white object-contain p-2",
									!logoLightSrc && "hidden",
								]}
							/>
							<Input
								id="logo_light"
								name="logo_light"
								type="file"
								accept="image/*"
								disabled={!canWrite}
								data-logo-input="logo_light"
							/>
							<label
								class:list={["flex items-center gap-2 text-sm", !logoLightSrc && "hidden"]}
								data-logo-remove="logo_light"
							>
								<input
									type="checkbox"
									name="remove_logo_light"
									value="1"
									disabled={!canWrite}
									data-logo-remove-check="logo_light"
								/>
								Quitar logo claro
							</label>
						</div>
						<div class="flex flex-col gap-2">
							<Label for="logo_dark">Logo (fondo oscuro)</Label>
							<img
								data-logo-preview="logo_dark"
								src={logoDarkSrc ?? ""}
								alt={restaurant.entry?.data.logo_dark?.alt ?? `${nombre} (oscuro)`}
								class:list={[
									"h-20 w-auto max-w-full rounded-md border border-border bg-neutral-900 object-contain p-2",
									!logoDarkSrc && "hidden",
								]}
							/>
							<Input
								id="logo_dark"
								name="logo_dark"
								type="file"
								accept="image/*"
								disabled={!canWrite}
								data-logo-input="logo_dark"
							/>
							<label
								class:list={["flex items-center gap-2 text-sm", !logoDarkSrc && "hidden"]}
								data-logo-remove="logo_dark"
							>
								<input
									type="checkbox"
									name="remove_logo_dark"
									value="1"
									disabled={!canWrite}
									data-logo-remove-check="logo_dark"
								/>
								Quitar logo oscuro
							</label>
						</div>
					</div>
					<p class="text-muted-foreground text-xs">
						Si solo subís uno, se usa ese en ambos modos del menú.
					</p>
					<div>
						<Button type="submit" variant="primary" disabled={!canWrite}>
							Guardar
						</Button>
					</div>
				</form>
			</CardContent>
		</Card>
	</div>
</Dashboard>

<script>
	function bindLogoPreviews(root: ParentNode = document) {
		const objectUrls = new Map<string, string>();

		for (const input of root.querySelectorAll<HTMLInputElement>("[data-logo-input]")) {
			const key = input.dataset.logoInput;
			if (!key) continue;

			input.addEventListener("change", () => {
				const preview = root.querySelector<HTMLImageElement>(
					`[data-logo-preview="${key}"]`,
				);
				const removeRow = root.querySelector<HTMLElement>(`[data-logo-remove="${key}"]`);
				const removeCheck = root.querySelector<HTMLInputElement>(
					`[data-logo-remove-check="${key}"]`,
				);
				if (!preview) return;

				const prev = objectUrls.get(key);
				if (prev) {
					URL.revokeObjectURL(prev);
					objectUrls.delete(key);
				}

				const file = input.files?.[0];
				if (!file) return;

				const url = URL.createObjectURL(file);
				objectUrls.set(key, url);
				preview.src = url;
				preview.classList.remove("hidden");
				removeRow?.classList.add("hidden");
				if (removeCheck) removeCheck.checked = false;
			});
		}
	}

	bindLogoPreviews();
	document.addEventListener("astro:page-load", () => bindLogoPreviews());
</script>
