---
import Dashboard from "../../layouts/Dashboard.astro";
import CategoryIcon from "../../components/CategoryIcon.astro";
import { requireOwner } from "../../lib/auth/require-owner";
import {
	assertCategoriaBelongsToRestaurant,
	createCategoriaViaApi,
	deleteCategoriaViaApi,
	formImageFile,
	getCategoriaBySlug,
	imageSrc,
	listCategoriasForRestaurant,
	updateCategoriaViaApi,
	uploadMediaViaApi,
	writesEnabled,
	type EmDashImage,
} from "../../lib/emdash/client";
import { loadOwnerRestaurant, savedRedirect } from "../../lib/emdash/owner-restaurant";
import { CATEGORY_ICON_OPTIONS, isCategoryIconId } from "../../lib/category-icons";
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/starwind/card";

export const prerender = false;

const auth = await requireOwner(Astro.request, Astro.cookies);
if (!auth.ok) {
	return Astro.redirect(auth.redirect);
}

const { owner } = auth;
const canWrite = writesEnabled();
let error: string | null = null;
const saved = Astro.url.searchParams.get("saved") === "1";
const savedAction = Astro.url.searchParams.get("action");
const restaurantId = owner.restaurant.emdash_restaurant_id;

/** Load an owned categoria or throw (also guards cross-tenant access). */
async function ownedCategoria(slug: string) {
	const { entry } = await getCategoriaBySlug(slug);
	if (!entry || !assertCategoriaBelongsToRestaurant(entry, restaurantId)) {
		throw new Error("Categoría no encontrada.");
	}
	return entry;
}

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("action") ?? "");

	if (!canWrite) {
		error = "Escrituras no configuradas (falta EMDASH_API_TOKEN).";
	} else {
		try {
			if (action === "create") {
				const label = String(form.get("label") ?? "").trim();
				if (!label) throw new Error("El nombre es obligatorio.");
				const { entries } = await listCategoriasForRestaurant(restaurantId);
				const maxOrden = entries.reduce(
					(max, c) => Math.max(max, c.data.orden ?? 0),
					-1,
				);
				await createCategoriaViaApi({
					nombre: label,
					restauranteId: restaurantId,
					orden: maxOrden + 1,
				});
				return Astro.redirect(savedRedirect("/app/categorias", { action: "create" }));
			} else if (action === "save") {
				const slug = String(form.get("slug") ?? "");
				const label = String(form.get("label") ?? "").trim();
				if (!slug || !label) throw new Error("Datos incompletos.");

				const entry = await ownedCategoria(slug);

				const iconRaw = String(form.get("icon") ?? "").trim();
				const icon = iconRaw && isCategoryIconId(iconRaw) ? iconRaw : null;
				const removeCover = form.get("remove_cover") === "1";
				const coverFile = formImageFile(form, "cover");

				let cover: EmDashImage | undefined;
				if (removeCover) {
					cover = null;
				} else if (coverFile) {
					cover = await uploadMediaViaApi(coverFile, label);
				}

				await updateCategoriaViaApi(entry.data.id, {
					nombre: label,
					icon,
					...(cover !== undefined ? { cover } : {}),
				});
				return Astro.redirect(savedRedirect("/app/categorias", { action: "save" }));
			} else if (action === "delete") {
				const slug = String(form.get("slug") ?? "");
				if (!slug) throw new Error("Slug requerido.");
				const entry = await ownedCategoria(slug);
				await deleteCategoriaViaApi(entry.data.id);
				return Astro.redirect(savedRedirect("/app/categorias", { action: "delete" }));
			}
		} catch (err) {
			error = err instanceof Error ? err.message : "Error al guardar categoría";
		}
	}
}

const restaurant = await loadOwnerRestaurant(owner, { chromeOnly: true });
const { entries: categorias, cacheHint } = await listCategoriasForRestaurant(restaurantId);
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const message = saved
	? savedAction === "delete"
		? "Categoría eliminada."
		: savedAction === "save"
			? "Categoría actualizada."
			: "Categoría creada."
	: null;
---

<Dashboard
	title="DigiMenu — Categorías"
	email={owner.email}
	restaurantSlug={restaurant.slug}
	restaurantName={restaurant.name}
>
	<div class="mx-auto flex max-w-2xl flex-col gap-6">
		<div>
			<h1 class="text-2xl font-semibold tracking-tight">Categorías</h1>
			<p class="text-muted-foreground">
				Secciones del menú. Opcionalmente elegí un icono y/o una imagen de portada.
			</p>
		</div>

		{message && <p class="text-sm text-success">{message}</p>}
		{error && <p class="text-sm text-error">{error}</p>}

		<Card>
			<CardHeader>
				<CardTitle>Nueva categoría</CardTitle>
				<CardDescription>Se usa para agrupar productos en el menú público.</CardDescription>
			</CardHeader>
			<CardContent>
				<form method="POST" class="flex flex-col gap-3 sm:flex-row sm:items-end" enctype="application/x-www-form-urlencoded">
					<input type="hidden" name="action" value="create" />
					<div class="flex flex-1 flex-col gap-1.5">
						<Label for="label">Nombre</Label>
						<Input id="label" name="label" required disabled={!canWrite} placeholder="Ej. Postres" />
					</div>
					<Button type="submit" variant="primary" disabled={!canWrite}>
						Agregar
					</Button>
				</form>
			</CardContent>
		</Card>

		<Card>
			<CardHeader>
				<CardTitle>Existentes</CardTitle>
			</CardHeader>
			<CardContent class="flex flex-col gap-6">
				{
					categorias.length === 0 ? (
						<p class="text-sm text-muted-foreground">No hay categorías todavía.</p>
					) : (
						categorias.map((cat) => {
							const coverSrc = imageSrc(cat.data.cover);
							const icon = cat.data.icon ?? null;
							return (
								<div class="flex flex-col gap-4 border-b border-border pb-6 last:border-0 last:pb-0">
									<form method="POST" class="flex flex-col gap-3" enctype="multipart/form-data">
										<input type="hidden" name="action" value="save" />
										<input type="hidden" name="slug" value={cat.id} />

										<div class="flex min-w-0 items-center gap-2">
											{icon && (
												<span class="shrink-0">
													<CategoryIcon icon={icon} class="size-5 shrink-0" />
												</span>
											)}
											<span class="inline-flex items-center rounded-md border border-border px-2 py-0.5 text-xs font-medium">
												{cat.id}
											</span>
											<Input
												name="label"
												required
												disabled={!canWrite}
												class="min-w-0"
												value={cat.data.nombre}
											/>
										</div>

										<div class="flex flex-col gap-1.5">
											<Label>Icono (opcional)</Label>
											<select
												name="icon"
												disabled={!canWrite}
												class="border-input bg-background focus-visible:ring-ring flex h-9 w-full rounded-md border px-3 py-1 text-sm shadow-xs focus-visible:ring-1 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50"
											>
												<option value="" selected={!icon}>
													Sin icono
												</option>
												{CATEGORY_ICON_OPTIONS.map((opt) => (
													<option value={opt.id} selected={icon === opt.id}>
														{opt.label}
													</option>
												))}
											</select>
										</div>

										<div class="flex flex-col gap-2">
											<Label>Portada (opcional)</Label>
											{coverSrc && (
												<img
													src={coverSrc}
													alt={cat.data.nombre}
													class="h-24 w-full max-w-sm rounded-md border border-border object-cover"
												/>
											)}
											<Input name="cover" type="file" accept="image/*" disabled={!canWrite} />
											{coverSrc && (
												<label class="flex items-center gap-2 text-sm">
													<input
														type="checkbox"
														name="remove_cover"
														value="1"
														disabled={!canWrite}
													/>
													Quitar portada
												</label>
											)}
										</div>

										<div class="flex flex-wrap gap-2">
											<Button type="submit" variant="primary" size="sm" disabled={!canWrite}>
												Guardar
											</Button>
										</div>
									</form>

									<form method="POST" enctype="application/x-www-form-urlencoded">
										<input type="hidden" name="action" value="delete" />
										<input type="hidden" name="slug" value={cat.id} />
										<Button type="submit" variant="ghost" size="sm" disabled={!canWrite}>
											Eliminar categoría
										</Button>
									</form>
								</div>
							);
						})
					)
				}
			</CardContent>
		</Card>
	</div>
</Dashboard>
