---
import Dashboard from "../../layouts/Dashboard.astro";
import { requireOwner, revalidateOwnerSession } from "../../lib/auth/require-owner";
import {
	createCategoriaViaApi,
	deleteCategoriaViaApi,
	updateCategoriaViaApi,
	writesEnabled,
} from "../../lib/emdash/client";
import { loadOwnerRestaurant, savedRedirect } from "../../lib/emdash/owner-restaurant";
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/starwind/card";

export const prerender = false;

const auth = await requireOwner(Astro.request, Astro.cookies);
if (!auth.ok) {
	return Astro.redirect(auth.redirect);
}

const { owner } = auth;
const canWrite = writesEnabled();
let error: string | null = null;
const saved = Astro.url.searchParams.get("saved") === "1";
const savedAction = Astro.url.searchParams.get("action");

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("action") ?? "");

	if (!canWrite) {
		error = "Escrituras no configuradas (falta EMDASH_API_TOKEN).";
	} else {
		try {
			if (action === "create") {
				const label = String(form.get("label") ?? "").trim();
				if (!label) throw new Error("El nombre es obligatorio.");
				await createCategoriaViaApi({ label });
				await revalidateOwnerSession(Astro.request, Astro.cookies);
				return Astro.redirect(savedRedirect("/app/categorias", { action: "create" }));
			} else if (action === "rename") {
				const slug = String(form.get("slug") ?? "");
				const label = String(form.get("label") ?? "").trim();
				if (!slug || !label) throw new Error("Datos incompletos.");
				await updateCategoriaViaApi(slug, { label });
				await revalidateOwnerSession(Astro.request, Astro.cookies);
				return Astro.redirect(savedRedirect("/app/categorias", { action: "rename" }));
			} else if (action === "delete") {
				const slug = String(form.get("slug") ?? "");
				if (!slug) throw new Error("Slug requerido.");
				await deleteCategoriaViaApi(slug);
				await revalidateOwnerSession(Astro.request, Astro.cookies);
				return Astro.redirect(savedRedirect("/app/categorias", { action: "delete" }));
			}
		} catch (err) {
			error = err instanceof Error ? err.message : "Error al guardar categoría";
		}
	}
}

const restaurant = await loadOwnerRestaurant(owner, { chromeOnly: true });
const restaurantId = owner.restaurant.emdash_restaurant_id;

const message = saved
	? savedAction === "delete"
		? "Categoría eliminada."
		: savedAction === "rename"
			? "Categoría actualizada."
			: "Categoría creada."
	: null;
---

<Dashboard
	title="DigiMenu — Categorías"
	email={owner.email}
	restaurantSlug={restaurant.slug}
	restaurantName={restaurant.name}
>
	<div class="mx-auto flex max-w-2xl flex-col gap-6">
		<div>
			<h1 class="text-2xl font-semibold tracking-tight">Categorías</h1>
			<p class="text-muted-foreground">Secciones del menú (taxonomy <code>categoria</code>).</p>
		</div>

		{message && <p class="text-sm text-success">{message}</p>}
		{error && <p class="text-sm text-error">{error}</p>}

		<Card>
			<CardHeader>
				<CardTitle>Nueva categoría</CardTitle>
				<CardDescription>Se usa para agrupar productos en el menú público.</CardDescription>
			</CardHeader>
			<CardContent>
				<form method="POST" class="flex flex-col gap-3 sm:flex-row sm:items-end" enctype="application/x-www-form-urlencoded">
					<input type="hidden" name="action" value="create" />
					<div class="flex flex-1 flex-col gap-1.5">
						<Label for="label">Nombre</Label>
						<Input id="label" name="label" required disabled={!canWrite} placeholder="Ej. Postres" />
					</div>
					<Button type="submit" variant="primary" disabled={!canWrite}>
						Agregar
					</Button>
				</form>
			</CardContent>
		</Card>

		<Card>
			<CardHeader>
				<CardTitle>Existentes</CardTitle>
			</CardHeader>
			<CardContent
				id="owner-categorias-list"
				class="flex flex-col gap-4"
				data-restaurant-id={restaurantId}
				data-can-write={canWrite ? "1" : "0"}
				aria-live="polite"
			>
				<p class="text-sm text-muted-foreground">Cargando categorías…</p>
			</CardContent>
		</Card>
	</div>
</Dashboard>

<script>
	import {
		bustOwnerListCaches,
		categoriasCacheKey,
		fetchCategorias,
		shouldBustFromUrl,
		swrLoad,
		type OwnerCategoriaRow,
	} from "../../lib/app/owner-browser-cache";

	const root = document.getElementById("owner-categorias-list");
	if (root) {
		const restaurantId = root.dataset.restaurantId ?? "";
		const canWrite = root.dataset.canWrite === "1";

		function escapeAttr(value: string) {
			return value.replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;");
		}

		function render(cats: OwnerCategoriaRow[]) {
			if (cats.length === 0) {
				root!.innerHTML =
					'<p class="text-sm text-muted-foreground">No hay categorías todavía.</p>';
				return;
			}

			root!.innerHTML = cats
				.map((cat) => {
					const disabled = canWrite ? "" : "disabled";
					return `
				<div class="flex flex-col gap-3 border-b border-border pb-4 last:border-0 last:pb-0 sm:flex-row sm:items-center">
					<form method="POST" class="flex flex-1 flex-col gap-2 sm:flex-row sm:items-center" enctype="application/x-www-form-urlencoded">
						<input type="hidden" name="action" value="rename" />
						<input type="hidden" name="slug" value="${escapeAttr(cat.slug)}" />
						<div class="flex min-w-0 flex-1 items-center gap-2">
							<span class="inline-flex items-center rounded-md border border-border px-2 py-0.5 text-xs font-medium">${escapeAttr(cat.slug)}</span>
							<input name="label" value="${escapeAttr(cat.label)}" required ${disabled} class="border-input bg-background ring-offset-background placeholder:text-muted-foreground focus-visible:ring-ring flex h-9 w-full rounded-md border px-3 py-1 text-sm shadow-xs transition-colors focus-visible:ring-1 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50" />
						</div>
						<button type="submit" ${disabled} class="border-input bg-background hover:bg-accent hover:text-accent-foreground inline-flex h-8 items-center justify-center rounded-md border px-3 text-sm font-medium shadow-xs disabled:pointer-events-none disabled:opacity-50">Renombrar</button>
					</form>
					<form method="POST" enctype="application/x-www-form-urlencoded">
						<input type="hidden" name="action" value="delete" />
						<input type="hidden" name="slug" value="${escapeAttr(cat.slug)}" />
						<button type="submit" ${disabled} class="hover:bg-accent hover:text-accent-foreground inline-flex h-8 items-center justify-center rounded-md px-3 text-sm font-medium disabled:pointer-events-none disabled:opacity-50">Eliminar</button>
					</form>
				</div>`;
				})
				.join("");
		}

		const bust = shouldBustFromUrl();
		if (bust) bustOwnerListCaches(restaurantId);

		void swrLoad({
			key: categoriasCacheKey(restaurantId),
			bust,
			fetcher: fetchCategorias,
			onLoading: () => {
				root!.innerHTML =
					'<p class="text-sm text-muted-foreground">Cargando categorías…</p>';
			},
			onData: (cats) => render(cats),
			onError: () => {
				root!.innerHTML =
					'<p class="text-sm text-error">No se pudieron cargar las categorías.</p>';
			},
		});
	}
</script>
