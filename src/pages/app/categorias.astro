---
import Dashboard from "../../layouts/Dashboard.astro";
import CategoryIcon from "../../components/CategoryIcon.astro";
import { requireOwner } from "../../lib/auth/require-owner";
import {
	assertCategoriaBelongsToRestaurant,
	createCategoriaViaApi,
	deleteCategoriaViaApi,
	formImageFile,
	getCategoriaBySlug,
	listCategoriasForRestaurant,
	updateCategoriaViaApi,
	uploadMediaViaApi,
	writesEnabled,
	type EmDashImage,
} from "../../lib/emdash/client";
import { loadOwnerRestaurant, savedRedirect } from "../../lib/emdash/owner-restaurant";
import { CATEGORY_ICON_OPTIONS, isCategoryIconId } from "../../lib/category-icons";
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/starwind/card";

export const prerender = false;

const auth = await requireOwner(Astro.request, Astro.cookies);
if (!auth.ok) {
	return Astro.redirect(auth.redirect);
}

const { owner } = auth;
const canWrite = writesEnabled();
let error: string | null = null;
const saved = Astro.url.searchParams.get("saved") === "1";
const savedAction = Astro.url.searchParams.get("action");
const restaurantId = owner.restaurant.emdash_restaurant_id;

/** Load an owned categoria or throw (also guards cross-tenant access). */
async function ownedCategoria(slug: string) {
	const { entry } = await getCategoriaBySlug(slug);
	if (!entry || !assertCategoriaBelongsToRestaurant(entry, restaurantId)) {
		throw new Error("Categoría no encontrada.");
	}
	return entry;
}

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("action") ?? "");

	if (!canWrite) {
		error = "Escrituras no configuradas (falta EMDASH_API_TOKEN).";
	} else {
		try {
			if (action === "create") {
				const label = String(form.get("label") ?? "").trim();
				if (!label) throw new Error("El nombre es obligatorio.");
				const { entries } = await listCategoriasForRestaurant(restaurantId);
				const maxOrden = entries.reduce(
					(max, c) => Math.max(max, c.data.orden ?? 0),
					-1,
				);
				await createCategoriaViaApi({
					nombre: label,
					restauranteId: restaurantId,
					orden: maxOrden + 1,
				});
				return Astro.redirect(savedRedirect("/app/categorias", { action: "create" }));
			} else if (action === "save") {
				const slug = String(form.get("slug") ?? "");
				const label = String(form.get("label") ?? "").trim();
				if (!slug || !label) throw new Error("Datos incompletos.");

				const entry = await ownedCategoria(slug);

				const iconRaw = String(form.get("icon") ?? "").trim();
				const icon = iconRaw && isCategoryIconId(iconRaw) ? iconRaw : null;
				const removeCover = form.get("remove_cover") === "1";
				const coverFile = formImageFile(form, "cover");

				let cover: EmDashImage | undefined;
				if (removeCover) {
					cover = null;
				} else if (coverFile) {
					cover = await uploadMediaViaApi(coverFile, label);
				}

				await updateCategoriaViaApi(entry.data.id, {
					nombre: label,
					icon,
					...(cover !== undefined ? { cover } : {}),
				});
				return Astro.redirect(savedRedirect("/app/categorias", { action: "save" }));
			} else if (action === "delete") {
				const slug = String(form.get("slug") ?? "");
				if (!slug) throw new Error("Slug requerido.");
				const entry = await ownedCategoria(slug);
				await deleteCategoriaViaApi(entry.data.id);
				return Astro.redirect(savedRedirect("/app/categorias", { action: "delete" }));
			}
		} catch (err) {
			error = err instanceof Error ? err.message : "Error al guardar categoría";
		}
	}
}

// List renders client-side from /app/api/categorias (sessionStorage SWR) —
// SSR stays cookie-only so navigations are light on Workers.
const restaurant = await loadOwnerRestaurant(owner, { chromeOnly: true });

const message = saved
	? savedAction === "delete"
		? "Categoría eliminada."
		: savedAction === "save"
			? "Categoría actualizada."
			: "Categoría creada."
	: null;
---

<Dashboard
	title="DigiMenu — Categorías"
	email={owner.email}
	restaurantSlug={restaurant.slug}
	restaurantName={restaurant.name}
>
	<div class="mx-auto flex max-w-2xl flex-col gap-6">
		<div>
			<h1 class="text-2xl font-semibold tracking-tight">Categorías</h1>
			<p class="text-muted-foreground">
				Secciones del menú. Opcionalmente elegí un icono y/o una imagen de portada.
			</p>
		</div>

		{message && <p class="text-sm text-success">{message}</p>}
		{error && <p class="text-sm text-error">{error}</p>}

		<Card>
			<CardHeader>
				<CardTitle>Nueva categoría</CardTitle>
				<CardDescription>Se usa para agrupar productos en el menú público.</CardDescription>
			</CardHeader>
			<CardContent>
				<form method="POST" class="flex flex-col gap-3 sm:flex-row sm:items-end" enctype="application/x-www-form-urlencoded">
					<input type="hidden" name="action" value="create" />
					<div class="flex flex-1 flex-col gap-1.5">
						<Label for="label">Nombre</Label>
						<Input id="label" name="label" required disabled={!canWrite} placeholder="Ej. Postres" />
					</div>
					<Button type="submit" variant="primary" disabled={!canWrite}>
						Agregar
					</Button>
				</form>
			</CardContent>
		</Card>

		<Card>
			<CardHeader>
				<CardTitle>Existentes</CardTitle>
			</CardHeader>
			<CardContent
				id="owner-categorias-list"
				class="flex flex-col gap-6"
				data-restaurant-id={restaurantId}
				aria-live="polite"
			>
				<p class="text-sm text-muted-foreground">Cargando categorías…</p>
			</CardContent>
		</Card>
	</div>

	{/* Per-category form, cloned client-side for each row. */}
	<template id="categoria-item-template">
		<div class="flex flex-col gap-4 border-b border-border pb-6 last:border-0 last:pb-0">
			<form method="POST" class="flex flex-col gap-3" enctype="multipart/form-data">
				<input type="hidden" name="action" value="save" />
				<input type="hidden" name="slug" value="" />

				<div class="flex min-w-0 items-center gap-2">
					<span data-icon-slot class="hidden shrink-0"></span>
					<span
						data-slug-badge
						class="inline-flex items-center rounded-md border border-border px-2 py-0.5 text-xs font-medium"
					></span>
					<Input name="label" required disabled={!canWrite} class="min-w-0" />
				</div>

				<div class="flex flex-col gap-1.5">
					<Label>Icono (opcional)</Label>
					<select
						name="icon"
						disabled={!canWrite}
						class="border-input bg-background focus-visible:ring-ring flex h-9 w-full rounded-md border px-3 py-1 text-sm shadow-xs focus-visible:ring-1 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50"
					>
						<option value="">Sin icono</option>
						{CATEGORY_ICON_OPTIONS.map((opt) => (
							<option value={opt.id}>{opt.label}</option>
						))}
					</select>
				</div>

				<div class="flex flex-col gap-2">
					<Label>Portada (opcional)</Label>
					<img
						data-cover-preview
						alt=""
						class="hidden h-24 w-full max-w-sm rounded-md border border-border object-cover"
					/>
					<Input name="cover" type="file" accept="image/*" disabled={!canWrite} />
					<label data-remove-cover class="hidden items-center gap-2 text-sm">
						<input type="checkbox" name="remove_cover" value="1" disabled={!canWrite} />
						Quitar portada
					</label>
				</div>

				<div class="flex flex-wrap gap-2">
					<Button type="submit" variant="primary" size="sm" disabled={!canWrite}>
						Guardar
					</Button>
				</div>
			</form>

			<form method="POST" enctype="application/x-www-form-urlencoded">
				<input type="hidden" name="action" value="delete" />
				<input type="hidden" name="slug" value="" />
				<Button type="submit" variant="ghost" size="sm" disabled={!canWrite}>
					Eliminar categoría
				</Button>
			</form>
		</div>
	</template>

	{/* SVG sprite so the client script can clone curated Tabler icons. */}
	<div id="categoria-icon-sprite" class="hidden" aria-hidden="true">
		{CATEGORY_ICON_OPTIONS.map((opt) => (
			<span data-icon={opt.id}>
				<CategoryIcon icon={opt.id} class="size-5 shrink-0" />
			</span>
		))}
	</div>
</Dashboard>

<script>
	import {
		categoriasCacheKey,
		fetchCategorias,
		shouldBustFromUrl,
		swrLoad,
		type OwnerCategoriaRow,
	} from "../../lib/app/owner-browser-cache";

	const root = document.getElementById("owner-categorias-list");
	const template = document.getElementById(
		"categoria-item-template",
	) as HTMLTemplateElement | null;
	const sprite = document.getElementById("categoria-icon-sprite");

	if (root && template) {
		const restaurantId = root.dataset.restaurantId ?? "";
		let renderedJson: string | null = null;

		function buildRow(row: OwnerCategoriaRow): DocumentFragment {
			const node = template!.content.cloneNode(true) as DocumentFragment;

			node.querySelectorAll<HTMLInputElement>('input[name="slug"]').forEach((el) => {
				el.value = row.slug;
			});

			const badge = node.querySelector("[data-slug-badge]");
			if (badge) badge.textContent = row.slug;

			const label = node.querySelector<HTMLInputElement>('input[name="label"]');
			if (label) label.value = row.label;

			const select = node.querySelector<HTMLSelectElement>('select[name="icon"]');
			if (select) select.value = row.icon ?? "";

			const iconSlot = node.querySelector("[data-icon-slot]");
			const iconSvg = row.icon
				? sprite?.querySelector(`[data-icon="${row.icon}"] svg`)
				: null;
			if (iconSlot && iconSvg) {
				iconSlot.appendChild(iconSvg.cloneNode(true));
				iconSlot.classList.remove("hidden");
			}

			if (row.coverSrc) {
				const cover = node.querySelector<HTMLImageElement>("[data-cover-preview]");
				if (cover) {
					cover.src = row.coverSrc;
					cover.alt = row.label;
					cover.classList.remove("hidden");
				}
				const removeCover = node.querySelector("[data-remove-cover]");
				if (removeCover) {
					removeCover.classList.remove("hidden");
					removeCover.classList.add("flex");
				}
			}

			return node;
		}

		function render(rows: OwnerCategoriaRow[]) {
			// Skip identical re-renders so a background refresh doesn't wipe edits in progress.
			const json = JSON.stringify(rows);
			if (json === renderedJson) return;
			renderedJson = json;

			if (rows.length === 0) {
				root!.innerHTML =
					'<p class="text-sm text-muted-foreground">No hay categorías todavía.</p>';
				return;
			}
			const frag = document.createDocumentFragment();
			for (const row of rows) frag.appendChild(buildRow(row));
			root!.replaceChildren(frag);
		}

		const bust = shouldBustFromUrl();
		void swrLoad({
			key: categoriasCacheKey(restaurantId),
			bust,
			fetcher: fetchCategorias,
			onLoading: () => {
				root!.innerHTML =
					'<p class="text-sm text-muted-foreground">Cargando categorías…</p>';
			},
			onData: (rows) => render(rows),
			onError: () => {
				root!.innerHTML =
					'<p class="text-sm text-error">No se pudieron cargar las categorías.</p>';
			},
		});
	}
</script>
