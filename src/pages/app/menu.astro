---
import Dashboard from "../../layouts/Dashboard.astro";
import { requireOwner, revalidateOwnerSession } from "../../lib/auth/require-owner";
import { updateRestauranteViaApi, writesEnabled } from "../../lib/emdash/client";
import { loadOwnerRestaurant, savedRedirect } from "../../lib/emdash/owner-restaurant";
import { parseMenuLayout, type MenuColumns, type MenuNavigation } from "../../lib/menu-layout";
import { Button } from "@/components/starwind/button";
import { Label } from "@/components/starwind/label";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/starwind/card";

export const prerender = false;

const auth = await requireOwner(Astro.request, Astro.cookies);
if (!auth.ok) {
	return Astro.redirect(auth.redirect);
}

const { owner } = auth;
const canWrite = writesEnabled();
let error: string | null = null;
const saved = Astro.url.searchParams.get("saved") === "1";

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const columns = (String(form.get("columns") ?? "1") === "2" ? 2 : 1) as MenuColumns;
	const navigation = (
		String(form.get("navigation") ?? "por_categorias") === "scroll_unico"
			? "scroll_unico"
			: "por_categorias"
	) as MenuNavigation;
	const showImages = form.get("showImages") === "on";
	const layout = { columns, navigation, showImages };

	if (!canWrite) {
		error = "Escrituras no configuradas (falta EMDASH_API_TOKEN).";
	} else {
		try {
			await updateRestauranteViaApi(owner.restaurant.emdash_restaurant_id, {
				menu_layout: layout,
			});
			await revalidateOwnerSession(Astro.request, Astro.cookies);
			return Astro.redirect(savedRedirect("/app/menu"));
		} catch (err) {
			error = err instanceof Error ? err.message : "No se pudo guardar";
		}
	}
}

const restaurant = await loadOwnerRestaurant(owner, {
	fromSession: true,
	cookies: Astro.cookies,
});
const layout = parseMenuLayout(restaurant.entry?.data.menu_layout);
---

<Dashboard
	title="DigiMenu — Tipo de menú"
	email={owner.email}
	restaurantSlug={restaurant.slug}
	restaurantName={restaurant.name}
>
	<div class="mx-auto flex max-w-2xl flex-col gap-6">
		<div>
			<h1 class="text-2xl font-semibold tracking-tight">Tipo de menú</h1>
			<p class="text-muted-foreground">
				Cómo se muestra el menú público: columnas, navegación e imágenes.
			</p>
		</div>

		{saved && <p class="text-sm text-success">Guardado. Abrí “Ver menú” para comprobar.</p>}
		{error && <p class="text-sm text-error">{error}</p>}

		<Card>
			<CardHeader>
				<CardTitle>Display</CardTitle>
				<CardDescription>Opciones provisionales v1 — se pueden ampliar después.</CardDescription>
			</CardHeader>
			<CardContent>
				<form method="POST" class="flex flex-col gap-5" enctype="application/x-www-form-urlencoded" data-astro-reload>
					<fieldset class="flex flex-col gap-2">
						<Label>Columnas</Label>
						<div class="flex flex-wrap gap-4">
							<label class="flex items-center gap-2 text-sm">
								<input
									type="radio"
									name="columns"
									value="1"
									checked={layout.columns === 1}
									disabled={!canWrite}
								/>
								1 columna
							</label>
							<label class="flex items-center gap-2 text-sm">
								<input
									type="radio"
									name="columns"
									value="2"
									checked={layout.columns === 2}
									disabled={!canWrite}
								/>
								2 columnas
							</label>
						</div>
					</fieldset>

					<fieldset class="flex flex-col gap-2">
						<Label>Navegación</Label>
						<div class="flex flex-wrap gap-4">
							<label class="flex items-center gap-2 text-sm">
								<input
									type="radio"
									name="navigation"
									value="por_categorias"
									checked={layout.navigation === "por_categorias"}
									disabled={!canWrite}
								/>
								Por categorías (secciones)
							</label>
							<label class="flex items-center gap-2 text-sm">
								<input
									type="radio"
									name="navigation"
									value="scroll_unico"
									checked={layout.navigation === "scroll_unico"}
									disabled={!canWrite}
								/>
								Scroll único (lista plana)
							</label>
						</div>
					</fieldset>

					<label class="flex items-center justify-between gap-4">
						<span>
							<span class="text-sm font-medium">Mostrar imágenes</span>
							<span class="block text-xs text-muted-foreground">Si el producto tiene foto.</span>
						</span>
						<input
							type="checkbox"
							id="showImages"
							name="showImages"
							checked={layout.showImages}
							disabled={!canWrite}
							class="size-4"
						/>
					</label>

					<div>
						<Button type="submit" variant="primary" disabled={!canWrite}>
							Guardar
						</Button>
					</div>
				</form>
			</CardContent>
		</Card>
	</div>
</Dashboard>
