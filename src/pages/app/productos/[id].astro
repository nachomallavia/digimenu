---
import Dashboard from "../../../layouts/Dashboard.astro";
import { requireOwner } from "../../../lib/auth/require-owner";
import {
	assertCategoriaBelongsToRestaurant,
	assertProductoBelongsToRestaurant,
	deleteProductoViaApi,
	formImageFile,
	getCategoriaBySlug,
	getProductoBySlug,
	imageSrc,
	listCategoriasForRestaurant,
	updateProductoViaApi,
	uploadMediaViaApi,
	writesEnabled,
} from "../../../lib/emdash/client";
import { loadOwnerRestaurant, savedRedirect } from "../../../lib/emdash/owner-restaurant";
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
import { Textarea } from "@/components/starwind/textarea";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/starwind/card";

export const prerender = false;

const auth = await requireOwner(Astro.request, Astro.cookies);
if (!auth.ok) {
	return Astro.redirect(auth.redirect);
}

const { owner } = auth;
const restaurant = await loadOwnerRestaurant(owner, { chromeOnly: true });
const canWrite = writesEnabled();
const restaurantId = owner.restaurant.emdash_restaurant_id;
const slug = Astro.params.id;
if (!slug) {
	return Astro.redirect("/app/productos");
}

let error: string | null = null;
const saved = Astro.url.searchParams.get("saved") === "1";

let { entry: producto } = await getProductoBySlug(slug);

if (!producto || !assertProductoBelongsToRestaurant(producto, restaurantId)) {
	return Astro.redirect("/app/productos");
}

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("action") ?? "save");

	if (!canWrite) {
		error = "Escrituras no configuradas (falta EMDASH_API_TOKEN).";
	} else {
		try {
			if (action === "delete") {
				await deleteProductoViaApi(producto.data.id);
				return Astro.redirect("/app/productos?fresh=1");
			}

			const nombre = String(form.get("nombre") ?? "").trim();
			const precio = Number(form.get("precio"));
			const descripcion = String(form.get("descripcion") ?? "").trim();
			const categoriaSlug = String(form.get("categoria") ?? "");
			const removeImage = form.get("remove_imagen") === "1";
			const imageFile = formImageFile(form, "imagen");

			if (!nombre || Number.isNaN(precio) || precio < 0) {
				throw new Error("Nombre y precio válidos son obligatorios.");
			}

			// Ownership check: the selected categoria must belong to this restaurant.
			let categoria: string | null = null;
			if (categoriaSlug) {
				const { entry: cat } = await getCategoriaBySlug(categoriaSlug);
				if (!cat || !assertCategoriaBelongsToRestaurant(cat, restaurantId)) {
					throw new Error("Categoría inválida.");
				}
				categoria = cat.data.id;
			}

			const update: {
				nombre: string;
				precio: number;
				descripcion: string | null;
				categoria: string | null;
				imagen?: Awaited<ReturnType<typeof uploadMediaViaApi>> | null;
			} = {
				nombre,
				precio,
				descripcion: descripcion || null,
				categoria,
			};

			if (removeImage) {
				update.imagen = null;
			} else if (imageFile) {
				update.imagen = await uploadMediaViaApi(imageFile, nombre);
			}

			await updateProductoViaApi(producto.data.id, update);
			return Astro.redirect(savedRedirect(`/app/productos/${slug}`));
		} catch (err) {
			error = err instanceof Error ? err.message : "No se pudo guardar";
			// Re-read so the form reflects the DB after a failed POST.
			const refreshed = await getProductoBySlug(slug);
			if (refreshed.entry) producto = refreshed.entry;
		}
	}
}

const { entries: categorias } = await listCategoriasForRestaurant(restaurantId);
const current = producto;
const selectedCategoriaId = current.data.categoria ?? null;
const imagenSrc = imageSrc(current.data.imagen) ?? null;
---

<Dashboard
	title={`DigiMenu — ${current.data.nombre}`}
	email={owner.email}
	restaurantSlug={restaurant.slug}
	restaurantName={restaurant.name}
>
	<div class="mx-auto flex max-w-2xl flex-col gap-6">
		<div>
			<p class="mb-1 text-sm">
				<a href="/app/productos" class="text-muted-foreground hover:text-foreground">
					← Productos
				</a>
			</p>
			<h1 class="text-2xl font-semibold tracking-tight">Detalle de producto</h1>
			<p class="text-muted-foreground">
				Slug <code class="text-sm">{current.id}</code>
			</p>
		</div>

		{saved && <p class="text-sm text-success">Producto actualizado.</p>}
		{error && <p class="text-sm text-error">{error}</p>}

		<Card>
			<CardHeader>
				<CardTitle>Editar</CardTitle>
				<CardDescription>Datos del producto, categoría e imagen.</CardDescription>
			</CardHeader>
			<CardContent>
				<form method="POST" class="flex flex-col gap-4" enctype="multipart/form-data" data-astro-reload>
					<input type="hidden" name="action" value="save" />
					<div class="flex flex-col gap-1.5">
						<Label for="nombre">Nombre</Label>
						<Input
							id="nombre"
							name="nombre"
							required
							value={current.data.nombre}
							disabled={!canWrite}
						/>
					</div>
					<div class="flex flex-col gap-1.5">
						<Label for="precio">Precio</Label>
						<Input
							id="precio"
							name="precio"
							type="number"
							min="0"
							step="1"
							required
							value={String(current.data.precio)}
							disabled={!canWrite}
						/>
					</div>
					<div class="flex flex-col gap-1.5">
						<Label for="descripcion">Descripción</Label>
						<Textarea id="descripcion" name="descripcion" rows={4} disabled={!canWrite}>
							{current.data.descripcion ?? ""}
						</Textarea>
					</div>

					<div class="flex flex-col gap-2">
						<Label for="imagen">Imagen</Label>
						{
							imagenSrc && (
								<img
									src={imagenSrc}
									alt={current.data.imagen?.alt ?? current.data.nombre}
									class="h-32 w-32 rounded-md border border-border object-cover"
								/>
							)
						}
						<Input
							id="imagen"
							name="imagen"
							type="file"
							accept="image/*"
							disabled={!canWrite}
						/>
						{
							imagenSrc && (
								<label class="flex items-center gap-2 text-sm">
									<input
										type="checkbox"
										name="remove_imagen"
										value="1"
										disabled={!canWrite}
									/>
									Quitar imagen
								</label>
							)
						}
					</div>

					<div class="flex flex-col gap-1.5">
						<Label for="categoria">Categoría</Label>
						{
							categorias.length === 0 ? (
								<p class="text-sm text-muted-foreground">
									No hay categorías. Creá alguna en{" "}
									<a href="/app/categorias" class="underline">
										Categorías
									</a>
									.
								</p>
							) : (
								<select
									id="categoria"
									name="categoria"
									disabled={!canWrite}
									class="border-input bg-background focus-visible:ring-ring flex h-9 w-full rounded-md border px-3 py-1 text-sm shadow-xs focus-visible:ring-1 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50"
								>
									<option value="">Sin categoría</option>
									{categorias.map((cat) => (
										<option value={cat.id} selected={selectedCategoriaId === cat.data.id}>
											{cat.data.nombre}
										</option>
									))}
								</select>
							)
						}
					</div>

					<div class="flex flex-wrap gap-2">
						<Button type="submit" variant="primary" disabled={!canWrite}>
							Guardar
						</Button>
					</div>
				</form>

				<form method="POST" class="mt-6 border-t border-border pt-4" enctype="application/x-www-form-urlencoded" data-astro-reload>
					<input type="hidden" name="action" value="delete" />
					<Button type="submit" variant="error" size="sm" disabled={!canWrite}>
						Eliminar producto
					</Button>
				</form>
			</CardContent>
		</Card>
	</div>
</Dashboard>
