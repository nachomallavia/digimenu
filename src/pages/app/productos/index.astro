---
import Dashboard from "@/layouts/Dashboard.astro";
import EditIcon from "@/assets/lucide-icons-svg/square-pen.svg";
import TrashIcon from "@/assets/lucide-icons-svg/trash-2.svg";
import { requireOwner } from "@/lib/auth/require-owner";
import {
	assertCategoriaBelongsToRestaurant,
	assertProductoBelongsToRestaurant,
	deleteProductoViaApi,
	getCategoriaBySlug,
	getProductoBySlug,
	listProductosForRestaurant,
	listCategoriasForRestaurant,
	updateProductosBatchViaApi,
	writesEnabled,
	type ProductoUpdateData,
} from "@/lib/emdash/client";
import { loadOwnerRestaurant } from "@/lib/emdash/owner-restaurant";
import { Button } from "@/components/starwind/button";
import {
	Dropdown,
	DropdownCheckboxItem,
	DropdownContent,
	DropdownTrigger,
} from "@/components/starwind/dropdown";
import { Input } from "@/components/starwind/input";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/starwind/select";

export const prerender = false;

const auth = await requireOwner(Astro.request, Astro.cookies);
if (!auth.ok) {
	return Astro.redirect(auth.redirect);
}

const { owner } = auth;
const restaurant = await loadOwnerRestaurant(owner, { chromeOnly: true });
const canWrite = writesEnabled();
const restaurantId = owner.restaurant.emdash_restaurant_id;

const contentType = Astro.request.headers.get("content-type") ?? "";
if (Astro.request.method === "POST" && contentType.includes("application/json")) {
	if (!canWrite) {
		return Response.json(
			{ ok: false, error: "Escrituras no configuradas (falta EMDASH_API_TOKEN)." },
			{ status: 403 },
		);
	}

	let body: unknown;
	try {
		body = await Astro.request.json();
	} catch {
		return Response.json({ ok: false, error: "JSON inválido." }, { status: 400 });
	}

	const action =
		typeof body === "object" && body && "action" in body
			? String((body as { action: unknown }).action ?? "")
			: "";

	if (action === "delete") {
		const id =
			typeof body === "object" && body && "id" in body
				? String((body as { id: unknown }).id ?? "")
				: "";
		if (!id) {
			return Response.json({ ok: false, error: "Id requerido." }, { status: 400 });
		}
		try {
			const { entry } = await getProductoBySlug(id);
			if (!entry || !assertProductoBelongsToRestaurant(entry, restaurantId)) {
				return Response.json({ ok: false, error: "Producto no encontrado." }, { status: 404 });
			}
			await deleteProductoViaApi(entry.data.id, restaurantId);
			return Response.json({ ok: true });
		} catch (err) {
			return Response.json(
				{ ok: false, error: err instanceof Error ? err.message : "No se pudo eliminar" },
				{ status: 500 },
			);
		}
	}

	if (action === "batchUpdate") {
		const changesRaw =
			typeof body === "object" && body && "changes" in body
				? (body as { changes: unknown }).changes
				: null;
		if (!changesRaw || typeof changesRaw !== "object" || Array.isArray(changesRaw)) {
			return Response.json({ ok: false, error: "changes inválido." }, { status: 400 });
		}

		const entries = Object.entries(changesRaw as Record<string, unknown>);
		if (entries.length === 0) {
			return Response.json({ ok: true, updated: 0 });
		}
		if (entries.length > 200) {
			return Response.json(
				{ ok: false, error: "Máximo 200 productos por guardado." },
				{ status: 400 },
			);
		}

		const allowedKeys = new Set(["nombre", "precio", "categoria"]);
		const validated: Record<string, ProductoUpdateData> = {};
		const failed: { id: string; error: string }[] = [];

		for (const [id, patchUnknown] of entries) {
			if (!id || typeof patchUnknown !== "object" || !patchUnknown || Array.isArray(patchUnknown)) {
				failed.push({ id: id || "(vacío)", error: "Patch inválido." });
				continue;
			}
			const patchObj = patchUnknown as Record<string, unknown>;
			const keys = Object.keys(patchObj);
			if (keys.length === 0 || keys.length > 3 || keys.some((k) => !allowedKeys.has(k))) {
				failed.push({ id, error: "Campos no permitidos." });
				continue;
			}

			try {
				const { entry } = await getProductoBySlug(id);
				if (!entry || !assertProductoBelongsToRestaurant(entry, restaurantId)) {
					failed.push({ id, error: "Producto no encontrado." });
					continue;
				}

				const data: ProductoUpdateData = {};

				if ("nombre" in patchObj) {
					const nombre = String(patchObj.nombre ?? "").trim();
					if (!nombre) {
						failed.push({ id, error: "Nombre obligatorio." });
						continue;
					}
					data.nombre = nombre;
				}

				if ("precio" in patchObj) {
					const precio = Number(patchObj.precio);
					if (!Number.isFinite(precio) || precio < 0) {
						failed.push({ id, error: "Precio inválido." });
						continue;
					}
					data.precio = Math.round(precio);
				}

				if ("categoria" in patchObj) {
					const raw = patchObj.categoria;
					if (raw === null || raw === "") {
						data.categoria = null;
					} else {
						const catId = String(raw);
						const { entry: cat } = await getCategoriaBySlug(catId);
						if (!cat || !assertCategoriaBelongsToRestaurant(cat, restaurantId)) {
							failed.push({ id, error: "Categoría inválida." });
							continue;
						}
						data.categoria = cat.data.id;
					}
				}

				validated[entry.data.id] = data;
			} catch (err) {
				failed.push({
					id,
					error: err instanceof Error ? err.message : "Error de validación",
				});
			}
		}

		try {
			const result =
				Object.keys(validated).length > 0
					? await updateProductosBatchViaApi(validated, restaurantId)
					: { updated: 0, failed: [] as { id: string; error: string }[] };

			const allFailed = [...failed, ...result.failed];
			return Response.json({
				ok: allFailed.length === 0,
				updated: result.updated,
				failed: allFailed,
			});
		} catch (err) {
			return Response.json(
				{
					ok: false,
					updated: 0,
					failed,
					error: err instanceof Error ? err.message : "No se pudo guardar",
				},
				{ status: 500 },
			);
		}
	}

	return Response.json({ ok: false, error: "Acción desconocida." }, { status: 400 });
}

const { entries: productos, cacheHint } = await listProductosForRestaurant(restaurantId);
const { entries: categorias } = await listCategoriasForRestaurant(restaurantId);
if (cacheHint && Astro.cache?.enabled) Astro.cache.set(cacheHint);

const categoriaIdsJson = JSON.stringify(categorias.map((c) => c.data.id));
---

<Dashboard
	title="DigiMenu — Productos"
	email={owner.email}
	restaurantSlug={restaurant.slug}
	restaurantName={restaurant.name}
>
	<div
		data-productos-editor
		data-can-write={canWrite ? "true" : "false"}
		data-categoria-ids={categoriaIdsJson}
		class="mx-auto flex max-w-full flex-col gap-12 pb-24"
	>
		<div class="flex flex-wrap items-end justify-between gap-3">
			<div class="w-full flex flex-wrap items-end justify-between gap-3">
				<div class="flex flex-col gap-1">
					<h1 class="text-2xl font-semibold tracking-tight">Productos</h1>
					<p class="text-muted-foreground">Items del menú de tu restaurante.</p>
				</div>

				<div class="flex gap-4">
					<Button variant="outline">Descargar CSV</Button>
					<Button variant="default">Subir CSV</Button>
				</div>
			</div>
		</div>
		<div class="w-full flex items-center justify-between gap-4">
			<Input
				type="search"
				placeholder="Buscar producto"
				class="w-full max-w-sm"
				data-productos-search
				autocomplete="off"
			/>
			<div class="flex gap-2">
				<Dropdown data-categoria-filter>
					<DropdownTrigger asChild>
						<Button variant="outline" data-categoria-filter-trigger>
							<span data-categoria-filter-label>Filtrar categorías</span>
						</Button>
					</DropdownTrigger>
					<DropdownContent align="end" class="max-h-72 overflow-y-auto">
						<div class="bg-popover sticky top-0 z-10 -mx-1 -mt-1 mb-1 border-b border-border p-2">
							<Input
								type="search"
								size="sm"
								placeholder="Buscar categoría"
								class="w-full"
								data-categoria-filter-search
								autocomplete="off"
							/>
							<button
								type="button"
								data-categoria-filter-clear
								hidden
								class="text-muted-foreground hover:bg-accent hover:text-accent-foreground mt-1.5 w-full rounded-sm px-2 py-1.5 text-left text-sm"
							>
								Limpiar filtro
							</button>
						</div>
						<DropdownCheckboxItem
							data-productos-cat-filter
							data-categoria-id=""
							closeOnClick={false}
						>
							Sin categoría
						</DropdownCheckboxItem>
						{categorias.map((c) => (
							<DropdownCheckboxItem
								data-productos-cat-filter
								data-categoria-id={c.data.id}
								closeOnClick={false}
							>
								{c.data.nombre}
							</DropdownCheckboxItem>
						))}
						<p
							data-categoria-filter-empty
							hidden
							class="text-muted-foreground py-4 text-center text-sm"
						>
							Ninguna categoría coincide.
						</p>
					</DropdownContent>
				</Dropdown>
				<Select defaultValue="20" data-page-size>
					<SelectTrigger>
						<SelectValue placeholder="Mostrar 20 productos" />
					</SelectTrigger>
					<SelectContent>
						<SelectItem value="10">Mostrar 10 productos</SelectItem>
						<SelectItem value="20">Mostrar 20 productos</SelectItem>
						<SelectItem value="50">Mostrar 50 productos</SelectItem>
						<SelectItem value="100">Mostrar 100 productos</SelectItem>
						<SelectItem value="all">Mostrar todos los productos</SelectItem>
					</SelectContent>
				</Select>
			</div>
		</div>

		<div class="overflow-x-auto rounded-md border border-border">
			<table class="w-full caption-bottom text-sm" data-productos-table>
				<thead class="[&_tr]:border-b">
					<tr class="border-b border-border">
						<th class="text-muted-foreground h-10 px-3 text-left align-middle font-medium">
							Nombre
						</th>
						<th class="text-muted-foreground h-10 px-3 text-left align-middle font-medium">
							Categoría
						</th>
						<th class="text-muted-foreground h-10 px-3 text-left align-middle font-medium">
							Precio
						</th>
						<th class="text-muted-foreground h-10 px-3 text-left align-middle font-medium">
							Acciones
						</th>
					</tr>
				</thead>
				<tbody class="[&_tr:last-child]:border-0" data-productos-tbody>
					{productos.length === 0 ? (
						<tr>
							<td colspan="4" class="text-muted-foreground p-6 text-center">
								No hay productos todavía.
							</td>
						</tr>
					) : (
						productos.map((p) => {
							const id = p.data.id;
							const catId = p.data.categoria ?? "";
							const detailHref = `/app/productos/${p.slug ?? id}`;
							return (
								<tr
									class="border-b border-border transition-colors"
									data-producto-row={id}
								>
									<td class="p-2 align-middle">
										<Input
											type="text"
											value={p.data.nombre}
											class="w-full min-w-[10rem]"
											required
											disabled={!canWrite}
											data-producto-id={id}
											data-field="nombre"
											data-original={p.data.nombre}
										/>
									</td>
									<td class="p-2 align-middle">
										<select
											class="border-input bg-background focus-visible:ring-ring flex h-9 w-full min-w-[9rem] rounded-md border px-3 py-1 text-sm shadow-xs focus-visible:ring-1 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50"
											disabled={!canWrite}
											data-producto-id={id}
											data-field="categoria"
											data-original={catId}
										>
											<option value="" selected={!catId}>
												Sin categoría
											</option>
											{categorias.map((c) => (
												<option
													value={c.data.id}
													selected={catId === c.data.id}
												>
													{c.data.nombre}
												</option>
											))}
										</select>
									</td>
									<td class="p-2 align-middle">
										<Input
											type="number"
											value={String(p.data.precio)}
											class="w-full min-w-[6rem]"
											min="0"
											step="1"
											required
											disabled={!canWrite}
											data-producto-id={id}
											data-field="precio"
											data-original={String(p.data.precio)}
										/>
									</td>
									<td class="p-2 align-middle">
										<div class="flex items-center gap-1">
											<Button variant="ghost" size="sm" href={detailHref} title="Editar detalle">
												<EditIcon class="w-4 h-4" />
											</Button>
											{canWrite && (
												<Button
													variant="ghost"
													size="sm"
													type="button"
													title="Eliminar"
													data-delete-id={id}
													data-delete-name={p.data.nombre}
												>
													<TrashIcon class="w-4 h-4" />
												</Button>
											)}
										</div>
									</td>
								</tr>
							);
						})
					)}
					<tr data-productos-search-empty hidden>
						<td
							colspan="4"
							class="text-muted-foreground p-6 text-center"
							data-productos-search-empty-message
						>
							Ningún producto coincide con la búsqueda.
						</td>
					</tr>
				</tbody>
			</table>
		</div>

		<div
			data-productos-pager
			hidden
			class="flex flex-wrap items-center justify-between gap-3"
		>
			<p class="text-muted-foreground text-sm" data-pager-label>Mostrando 0–0 de 0</p>
			<div class="flex gap-2">
				<Button type="button" variant="outline" size="sm" data-page-prev disabled>
					Anterior
				</Button>
				<Button type="button" variant="outline" size="sm" data-page-next disabled>
					Siguiente
				</Button>
			</div>
		</div>

		<div
			data-productos-sticky
			hidden
			class="pointer-events-none fixed inset-x-0 bottom-0 z-40 flex justify-center px-4 pb-4 md:pl-[calc(var(--sidebar-width,16rem)+1rem)]"
		>
			<div
				class="pointer-events-auto flex w-full max-w-xl items-center justify-between gap-3 rounded-lg border border-border bg-background px-4 py-3 shadow-lg"
			>
				<p class="text-sm font-medium" data-sticky-label>Guardar 0 cambios</p>
				<div class="flex gap-2">
					<Button type="button" variant="outline" size="sm" data-discard-edits>
						Descartar
					</Button>
					<Button type="button" variant="primary" size="sm" data-save-edits>
						Guardar
					</Button>
				</div>
			</div>
		</div>

		<div
			data-owner-toast
			hidden
			role="status"
			class="fixed bottom-20 left-1/2 z-50 max-w-sm -translate-x-1/2 rounded-md border px-4 py-2 text-sm shadow-lg data-[toast-type=success]:border-success/40 data-[toast-type=success]:bg-background data-[toast-type=success]:text-success data-[toast-type=error]:border-error/40 data-[toast-type=error]:bg-background data-[toast-type=error]:text-error md:bottom-24"
		>
			<span data-owner-toast-message></span>
		</div>
	</div>
</Dashboard>

<script>
	import { postBatchUpdate, postDelete } from "@/lib/owner-edits/batch-client";
	import {
		currentPage,
		discardProductoEdits,
		dropProductoPending,
		fieldErrors,
		markProductosSaved,
		pageSize,
		pending,
		productosHasFieldErrors,
		productosPendingCount,
		saving,
		searchQuery,
		selectedCategorias,
		setProductoField,
		setProductoFieldError,
		showToast,
		type PageSize,
		type ProductoField,
		type ProductoPatch,
	} from "@/lib/owner-edits/productos-edits";
	import { bindToastHost } from "@/lib/owner-edits/toast-ui";
	import type { SelectChangeEvent } from "@/components/starwind/select";

	function parsePageSize(raw: string): PageSize | null {
		if (raw === "all") return "all";
		const n = Number(raw);
		if (n === 10 || n === 20 || n === 50 || n === 100) return n;
		return null;
	}

	function initProductosEditor() {
		const rootEl = document.querySelector<HTMLElement>("[data-productos-editor]");
		if (!rootEl || rootEl.dataset.bound === "1") return;
		rootEl.dataset.bound = "1";
		const root = rootEl;

		const canWrite = root.dataset.canWrite === "true";
		const sticky = root.querySelector<HTMLElement>("[data-productos-sticky]");
		const stickyLabel = root.querySelector<HTMLElement>("[data-sticky-label]");
		const saveBtn = root.querySelector<HTMLButtonElement>("[data-save-edits]");
		const discardBtn = root.querySelector<HTMLButtonElement>("[data-discard-edits]");
		const tbody = root.querySelector<HTMLElement>("[data-productos-tbody]");
		const toastHost = root.querySelector<HTMLElement>("[data-owner-toast]");
		const searchInput = root.querySelector<HTMLInputElement>("[data-productos-search]");
		const searchEmpty = root.querySelector<HTMLElement>("[data-productos-search-empty]");
		const searchEmptyMessage = root.querySelector<HTMLElement>(
			"[data-productos-search-empty-message]",
		);
		const pageSizeSelect = root.querySelector<HTMLElement>("[data-page-size]");
		const categoriaFilter = root.querySelector<HTMLElement>("[data-categoria-filter]");
		const categoriaFilterTrigger = root.querySelector<HTMLElement>(
			"[data-categoria-filter-trigger]",
		);
		const categoriaFilterLabel = root.querySelector<HTMLElement>("[data-categoria-filter-label]");
		const categoriaFilterContent = categoriaFilter?.querySelector<HTMLElement>(
			'[data-slot="dropdown-content"]',
		);
		const categoriaFilterSearch = categoriaFilterContent?.querySelector<HTMLInputElement>(
			"[data-categoria-filter-search]",
		);
		const categoriaFilterClear = categoriaFilterContent?.querySelector<HTMLButtonElement>(
			"[data-categoria-filter-clear]",
		);
		const categoriaFilterEmpty = categoriaFilterContent?.querySelector<HTMLElement>(
			"[data-categoria-filter-empty]",
		);
		const pager = root.querySelector<HTMLElement>("[data-productos-pager]");
		const pagerLabel = root.querySelector<HTMLElement>("[data-pager-label]");
		const pagePrevBtn = root.querySelector<HTMLButtonElement>("[data-page-prev]");
		const pageNextBtn = root.querySelector<HTMLButtonElement>("[data-page-next]");

		if (toastHost) bindToastHost(toastHost);

		searchQuery.set("");
		pageSize.set(20);
		currentPage.set(1);
		selectedCategorias.set([]);
		if (searchInput) searchInput.value = "";
		if (categoriaFilterSearch) categoriaFilterSearch.value = "";

		function foldSearchText(value: string): string {
			return value
				.trim()
				.toLowerCase()
				.normalize("NFD")
				.replace(/[\u0300-\u036f]/g, "");
		}

		function sizeCategoriaFilter() {
			if (!categoriaFilterTrigger || !categoriaFilterContent) return;

			const prevDisplay = categoriaFilterContent.style.display;
			const prevVisibility = categoriaFilterContent.style.visibility;
			const prevWidth = categoriaFilterContent.style.width;
			const prevMinWidth = categoriaFilterContent.style.minWidth;
			const prevMaxHeight = categoriaFilterContent.style.maxHeight;
			const wasHidden = getComputedStyle(categoriaFilterContent).display === "none";

			if (wasHidden) {
				categoriaFilterContent.style.visibility = "hidden";
				categoriaFilterContent.style.display = "block";
			}
			categoriaFilterContent.style.width = "max-content";
			categoriaFilterContent.style.minWidth = "0";
			categoriaFilterContent.style.maxHeight = "none";

			const longestOptionWidth = categoriaFilterContent.offsetWidth;

			categoriaFilterContent.style.display = prevDisplay;
			categoriaFilterContent.style.visibility = prevVisibility;
			categoriaFilterContent.style.width = prevWidth;
			categoriaFilterContent.style.minWidth = prevMinWidth;
			categoriaFilterContent.style.maxHeight = prevMaxHeight;

			const width = Math.max(categoriaFilterTrigger.offsetWidth, longestOptionWidth);
			categoriaFilterTrigger.style.minWidth = `${width}px`;
			categoriaFilterContent.style.minWidth = `${width}px`;
		}

		function filterCategoriaOptions() {
			const query = foldSearchText(categoriaFilterSearch?.value ?? "");
			const items = categoriaFilterContent?.querySelectorAll<HTMLElement>(
				"[data-productos-cat-filter]",
			);
			let visible = 0;
			items?.forEach((item) => {
				const label = foldSearchText(item.textContent ?? "");
				const match = !query || label.includes(query);
				item.hidden = !match;
				if (match) visible += 1;
			});
			if (categoriaFilterEmpty) {
				categoriaFilterEmpty.hidden = !(query && visible === 0);
			}
		}

		function syncCategoriaCheckboxUi() {
			const selected = new Set(selectedCategorias.get());
			categoriaFilterContent
				?.querySelectorAll<HTMLElement>("[data-productos-cat-filter]")
				.forEach((item) => {
					const id = item.getAttribute("data-categoria-id");
					if (id === null) return;
					item.setAttribute("aria-checked", selected.has(id) ? "true" : "false");
				});
		}

		function updateCategoriaFilterLabel() {
			const n = selectedCategorias.get().length;
			if (categoriaFilterLabel) {
				categoriaFilterLabel.textContent =
					n > 0 ? `Filtrando categorías (${n})` : "Filtrar categorías";
			}
			if (categoriaFilterClear) {
				categoriaFilterClear.hidden = n === 0;
			}
		}

		function clearCategoriaFilter() {
			selectedCategorias.set([]);
			currentPage.set(1);
			if (categoriaFilterSearch) {
				categoriaFilterSearch.value = "";
				filterCategoriaOptions();
			}
			syncCategoriaCheckboxUi();
			updateCategoriaFilterLabel();
		}

		function updatePagerUI(from: number, to: number, total: number, hide: boolean) {
			if (pagerLabel) {
				pagerLabel.textContent = `Mostrando ${from}–${to} de ${total}`;
			}
			if (pager) pager.hidden = hide;
			const page = currentPage.get();
			const ps = pageSize.get();
			const size = ps === "all" ? total : ps;
			const maxPage = size > 0 ? Math.max(1, Math.ceil(total / size)) : 1;
			if (pagePrevBtn) pagePrevBtn.disabled = page <= 1;
			if (pageNextBtn) pageNextBtn.disabled = page >= maxPage;
		}

		function applyListView() {
			const query = foldSearchText(searchQuery.get());
			const selected = selectedCategorias.get();
			const rows = Array.from(root.querySelectorAll<HTMLElement>("[data-producto-row]"));
			const matched: HTMLElement[] = [];

			for (const row of rows) {
				const nombreEl = row.querySelector<HTMLInputElement>('[data-field="nombre"]');
				const nombre = foldSearchText(nombreEl?.value ?? "");
				const catEl = row.querySelector<HTMLSelectElement>('[data-field="categoria"]');
				const catId = catEl?.value ?? "";
				const catOk = selected.length === 0 || selected.includes(catId);
				const match = (!query || nombre.includes(query)) && catOk;
				if (match) matched.push(row);
				else row.hidden = true;
			}

			const total = matched.length;
			const filtersActive = Boolean(query) || selected.length > 0;
			if (searchEmpty) {
				searchEmpty.hidden = !(filtersActive && rows.length > 0 && total === 0);
			}
			if (searchEmptyMessage) {
				searchEmptyMessage.textContent =
					selected.length > 0
						? "Ningún producto coincide con los filtros."
						: "Ningún producto coincide con la búsqueda.";
			}

			const ps = pageSize.get();
			if (ps === "all") {
				for (const row of matched) row.hidden = false;
				updatePagerUI(total === 0 ? 0 : 1, total, total, true);
				return;
			}

			const size = ps;
			const maxPage = Math.max(1, Math.ceil(total / size) || 1);
			const page = currentPage.get();
			const clamped = Math.min(Math.max(1, page), maxPage);
			if (clamped !== page) {
				currentPage.set(clamped);
				return;
			}

			const start = total === 0 ? 0 : (page - 1) * size;
			const end = Math.min(start + size, total);
			matched.forEach((row, i) => {
				row.hidden = i < start || i >= end;
			});

			const from = total === 0 ? 0 : start + 1;
			const to = total === 0 ? 0 : end;
			updatePagerUI(from, to, total, total <= size);
		}

		searchInput?.addEventListener("input", () => {
			currentPage.set(1);
			searchQuery.set(searchInput.value);
		});

		pageSizeSelect?.addEventListener("starwind-select:change", ((e: SelectChangeEvent) => {
			const next = parsePageSize(e.detail.value);
			if (next === null) return;
			pageSize.set(next);
			currentPage.set(1);
		}) as EventListener);

		// Dropdown content is portaled to document.body, so the change event
		// does not bubble through [data-categoria-filter] — listen on document.
		document.addEventListener("starwind-dropdown-checkbox:change", ((
			e: CustomEvent<{ checked: boolean }>,
		) => {
			if (!root.isConnected) return;
			const item = (e.target as HTMLElement | null)?.closest<HTMLElement>(
				"[data-productos-cat-filter]",
			);
			if (!item) return;
			const id = item.getAttribute("data-categoria-id");
			if (id === null) return;
			const current = selectedCategorias.get();
			if (e.detail.checked) {
				if (!current.includes(id)) selectedCategorias.set([...current, id]);
			} else {
				selectedCategorias.set(current.filter((c) => c !== id));
			}
			currentPage.set(1);
			updateCategoriaFilterLabel();
		}) as EventListener);

		categoriaFilterSearch?.addEventListener("input", () => {
			filterCategoriaOptions();
		});
		categoriaFilterSearch?.addEventListener("keydown", (e) => {
			// Keep Dropdown keyboard nav from stealing typing / Space / Enter.
			e.stopPropagation();
		});
		categoriaFilterSearch?.addEventListener("click", (e) => {
			e.stopPropagation();
		});

		categoriaFilterClear?.addEventListener("click", (e) => {
			e.preventDefault();
			e.stopPropagation();
			clearCategoriaFilter();
		});

		pagePrevBtn?.addEventListener("click", () => {
			currentPage.set(Math.max(1, currentPage.get() - 1));
		});
		pageNextBtn?.addEventListener("click", () => {
			currentPage.set(currentPage.get() + 1);
		});

		searchQuery.subscribe(applyListView);
		pageSize.subscribe(applyListView);
		currentPage.subscribe(applyListView);
		selectedCategorias.subscribe(applyListView);
		updateCategoriaFilterLabel();
		filterCategoriaOptions();
		sizeCategoriaFilter();
		applyListView();

		let categoriaIds = new Set<string>();
		try {
			const parsed = JSON.parse(root.dataset.categoriaIds ?? "[]") as unknown;
			if (Array.isArray(parsed)) {
				categoriaIds = new Set(parsed.map(String));
			}
		} catch {
			categoriaIds = new Set();
		}

		function originalOf(el: HTMLElement): string {
			return el.dataset.original ?? "";
		}

		function parseOriginalCategoria(raw: string): string | null {
			return raw === "" ? null : raw;
		}

		function parseOriginalPrecio(raw: string): number {
			return Number(raw);
		}

		function syncDirtyRows() {
			const map = pending.get();
			root.querySelectorAll<HTMLElement>("[data-producto-row]").forEach((row) => {
				const id = row.dataset.productoRow;
				if (!id) return;
				row.toggleAttribute("data-dirty", Boolean(map[id]));
				row.classList.toggle("bg-muted/40", Boolean(map[id]));
			});
		}

		function syncFieldErrorStyles() {
			const errs = fieldErrors.get();
			root.querySelectorAll<HTMLElement>("[data-field]").forEach((el) => {
				const id = el.dataset.productoId;
				const field = el.dataset.field as ProductoField | undefined;
				if (!id || !field) return;
				const hasErr = Boolean(errs[id]?.[field]);
				el.classList.toggle("border-error", hasErr);
				el.setAttribute("aria-invalid", hasErr ? "true" : "false");
			});
		}

		function updateSticky() {
			if (!sticky || !stickyLabel || !saveBtn || !discardBtn) return;
			const n = productosPendingCount.get();
			const isSaving = saving.get();
			const hasErrors = productosHasFieldErrors.get();
			sticky.hidden = n === 0 && !isSaving;
			stickyLabel.textContent = isSaving
				? "Guardando…"
				: `Guardar ${n} cambio${n === 1 ? "" : "s"}`;
			saveBtn.disabled = !canWrite || n === 0 || isSaving || hasErrors;
			discardBtn.disabled = isSaving || n === 0;
			syncDirtyRows();
			syncFieldErrorStyles();
		}

		productosPendingCount.subscribe(updateSticky);
		saving.subscribe(updateSticky);
		productosHasFieldErrors.subscribe(updateSticky);
		fieldErrors.subscribe(syncFieldErrorStyles);
		pending.subscribe(syncDirtyRows);
		updateSticky();

		function applyField(el: HTMLInputElement | HTMLSelectElement) {
			const id = el.dataset.productoId;
			const field = el.dataset.field as ProductoField | undefined;
			if (!id || !field || !canWrite) return;

			if (field === "nombre") {
				const trimmed = el.value.trim();
				const original = originalOf(el);
				if (!trimmed) {
					setProductoFieldError(id, "nombre", "Nombre obligatorio");
					// Keep out of pending until valid
					setProductoField(id, "nombre", original, original);
					applyListView();
					return;
				}
				setProductoFieldError(id, "nombre", null);
				setProductoField(id, "nombre", trimmed, original);
				applyListView();
				return;
			}

			if (field === "precio") {
				const precio = Number(el.value);
				const original = parseOriginalPrecio(originalOf(el));
				if (!Number.isFinite(precio) || precio < 0) {
					setProductoFieldError(id, "precio", "Precio inválido");
					setProductoField(id, "precio", original, original);
					return;
				}
				setProductoFieldError(id, "precio", null);
				setProductoField(id, "precio", Math.round(precio), original);
				return;
			}

			if (field === "categoria") {
				const raw = el.value;
				const value = raw === "" ? null : raw;
				const original = parseOriginalCategoria(originalOf(el));
				if (value !== null && !categoriaIds.has(value)) {
					setProductoFieldError(id, "categoria", "Categoría inválida");
					setProductoField(id, "categoria", original, original);
					applyListView();
					return;
				}
				setProductoFieldError(id, "categoria", null);
				setProductoField(id, "categoria", value, original);
				applyListView();
			}
		}

		tbody?.addEventListener("change", (e) => {
			const t = e.target;
			if (!(t instanceof HTMLInputElement || t instanceof HTMLSelectElement)) return;
			if (!t.dataset.field) return;
			applyField(t);
		});

		tbody?.addEventListener(
			"blur",
			(e) => {
				const t = e.target;
				if (!(t instanceof HTMLInputElement)) return;
				if (!t.dataset.field) return;
				applyField(t);
			},
			true,
		);

		function restoreDomFromOriginals() {
			root.querySelectorAll<HTMLInputElement | HTMLSelectElement>("[data-field]").forEach((el) => {
				const field = el.dataset.field;
				const original = originalOf(el);
				if (field === "nombre" || field === "precio" || field === "categoria") {
					el.value = original;
				}
			});
		}

		function syncOriginalsFromPatch(id: string, patch: ProductoPatch) {
			const row = root.querySelector<HTMLElement>(`[data-producto-row="${id}"]`);
			if (!row) return;
			if (patch.nombre !== undefined) {
				const el = row.querySelector<HTMLInputElement>('[data-field="nombre"]');
				if (el) {
					el.dataset.original = patch.nombre;
					el.value = patch.nombre;
				}
			}
			if (patch.precio !== undefined) {
				const el = row.querySelector<HTMLInputElement>('[data-field="precio"]');
				if (el) {
					el.dataset.original = String(patch.precio);
					el.value = String(patch.precio);
				}
			}
			if (patch.categoria !== undefined) {
				const el = row.querySelector<HTMLSelectElement>('[data-field="categoria"]');
				if (el) {
					const v = patch.categoria ?? "";
					el.dataset.original = v;
					el.value = v;
				}
			}
		}

		discardBtn?.addEventListener("click", () => {
			if (saving.get()) return;
			restoreDomFromOriginals();
			discardProductoEdits();
			updateSticky();
		});

		saveBtn?.addEventListener("click", async () => {
			if (!canWrite || saving.get()) return;
			if (productosHasFieldErrors.get()) {
				showToast("error", "Corregí los campos inválidos antes de guardar.");
				return;
			}
			const changes = pending.get();
			const ids = Object.keys(changes);
			if (ids.length === 0) return;

			saving.set(true);
			try {
				const result = await postBatchUpdate("/app/productos", changes);
				const failedIds = new Set((result.failed ?? []).map((f) => f.id));
				const savedIds = ids.filter((id) => !failedIds.has(id));

				for (const id of savedIds) {
					const patch = changes[id];
					if (patch) syncOriginalsFromPatch(id, patch);
				}
				markProductosSaved(savedIds);

				if (result.ok) {
					showToast(
						"success",
						`${result.updated ?? savedIds.length} producto${(result.updated ?? savedIds.length) === 1 ? "" : "s"} actualizado${(result.updated ?? savedIds.length) === 1 ? "" : "s"}.`,
					);
				} else {
					const failCount = result.failed?.length ?? 0;
					showToast(
						"error",
						failCount
							? `${result.updated ?? 0} guardados, ${failCount} fallaron.`
							: (result.error ?? "No se pudieron guardar los cambios."),
					);
				}
			} catch (err) {
				showToast("error", err instanceof Error ? err.message : "Error de red");
			} finally {
				saving.set(false);
			}
		});

		root.addEventListener("click", async (e) => {
			const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-delete-id]");
			if (!btn || !canWrite || saving.get()) return;
			e.preventDefault();
			const id = btn.dataset.deleteId;
			const name = btn.dataset.deleteName ?? "este producto";
			if (!id) return;
			if (!confirm(`¿Eliminar “${name}”? Esta acción no se puede deshacer.`)) return;

			try {
				const result = await postDelete("/app/productos", id);
				if (!result.ok) {
					showToast("error", result.error ?? "No se pudo eliminar");
					return;
				}
				dropProductoPending(id);
				root.querySelector(`[data-producto-row="${id}"]`)?.remove();
				applyListView();
				showToast("success", "Producto eliminado.");
			} catch (err) {
				showToast("error", err instanceof Error ? err.message : "Error de red");
			}
		});

		window.addEventListener("beforeunload", (e) => {
			if (productosPendingCount.get() > 0) {
				e.preventDefault();
				e.returnValue = "";
			}
		});
	}

	initProductosEditor();
	document.addEventListener("astro:page-load", initProductosEditor);
</script>
