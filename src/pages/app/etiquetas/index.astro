---
import Dashboard from "@/layouts/Dashboard.astro";
import { requireOwner } from "@/lib/auth/require-owner";
import {
	assertTagBelongsToRestaurant,
	deleteTagViaApi,
	getTagBySlug,
	listTagsForRestaurant,
	updateTagViaApi,
	writesEnabled,
} from "@/lib/emdash/client";
import { loadOwnerRestaurant, savedRedirect } from "@/lib/emdash/owner-restaurant";
import { Button } from "@/components/starwind/button";
import { Input } from "@/components/starwind/input";
import PlusIcon from "@tabler/icons/outline/plus.svg";

export const prerender = false;

const auth = await requireOwner(Astro.request, Astro.cookies);
if (!auth.ok) {
	return Astro.redirect(auth.redirect);
}

const { owner } = auth;
const canWrite = writesEnabled();
let error: string | null = null;
const saved = Astro.url.searchParams.get("saved") === "1";
const restaurantId = owner.restaurant.emdash_restaurant_id;

async function ownedTag(slug: string) {
	const { entry } = await getTagBySlug(slug);
	if (!entry || !assertTagBelongsToRestaurant(entry, restaurantId)) {
		throw new Error("Etiqueta no encontrada.");
	}
	return entry;
}

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("action") ?? "");

	if (!canWrite) {
		error = "Escrituras no configuradas (falta EMDASH_API_TOKEN).";
	} else {
		try {
			if (action === "save") {
				const slug = String(form.get("slug") ?? "");
				const nombre = String(form.get("nombre") ?? "").trim();
				if (!slug || !nombre) throw new Error("Datos incompletos.");
				const entry = await ownedTag(slug);
				await updateTagViaApi(entry.data.id, { nombre }, restaurantId);
				return Astro.redirect(savedRedirect("/app/etiquetas", { action: "save" }));
			}
			if (action === "delete") {
				const slug = String(form.get("slug") ?? "");
				const entry = await ownedTag(slug);
				await deleteTagViaApi(entry.data.id, restaurantId);
				return Astro.redirect(savedRedirect("/app/etiquetas", { action: "delete" }));
			}
		} catch (err) {
			error = err instanceof Error ? err.message : "No se pudo guardar";
		}
	}
}

const restaurant = await loadOwnerRestaurant(owner, { chromeOnly: true });
let tags: Awaited<ReturnType<typeof listTagsForRestaurant>>["entries"] = [];
try {
	({ entries: tags } = await listTagsForRestaurant(restaurantId));
} catch (err) {
	error = error ?? (err instanceof Error ? err.message : "No se pudieron cargar las etiquetas");
}
---

<Dashboard
	title="DigiMenu — Etiquetas"
	email={owner.email}
	restaurantSlug={restaurant.slug}
	restaurantName={restaurant.name}
>
	<div class="mx-auto flex max-w-2xl flex-col gap-6">
		<div class="flex flex-wrap items-start justify-between gap-3">
			<div>
				<h1 class="text-2xl font-semibold tracking-tight">Etiquetas</h1>
				<p class="text-muted-foreground">
					Etiquetas del restaurante (vegano, picante…). Se asignan a productos más adelante.
				</p>
			</div>
			{
				canWrite && (
					<Button href="/app/etiquetas/new" variant="primary" size="sm">
						<PlusIcon class="size-4" />
						Nueva etiqueta
					</Button>
				)
			}
		</div>

		{saved && <p class="text-sm text-success">Guardado.</p>}
		{error && <p class="text-sm text-error">{error}</p>}

		{
			tags.length === 0 ? (
				<p class="text-sm text-muted-foreground">Todavía no hay etiquetas.</p>
			) : (
				<ul class="flex flex-col gap-2">
					{tags.map((tag) => {
						const pathId = tag.slug ?? tag.id;
						return (
							<li class="rounded-lg border border-border p-3">
								<form method="POST" class="flex flex-wrap items-end gap-2" data-astro-reload>
									<input type="hidden" name="slug" value={pathId} />
									<div class="min-w-[10rem] flex-1">
										<label class="text-xs text-muted-foreground" for={`nombre-${pathId}`}>
											Nombre
										</label>
										<Input
											id={`nombre-${pathId}`}
											name="nombre"
											value={tag.data.nombre}
											disabled={!canWrite}
										/>
									</div>
									{canWrite && (
										<>
											<Button type="submit" name="action" value="save" size="sm" variant="primary">
												Guardar
											</Button>
											<Button
												type="submit"
												name="action"
												value="delete"
												size="sm"
												variant="ghost"
												onclick="return confirm('¿Borrar esta etiqueta?');"
											>
												Borrar
											</Button>
										</>
									)}
								</form>
							</li>
						);
					})}
				</ul>
			)
		}
	</div>
</Dashboard>
