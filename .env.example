PUBLIC_SUPABASE_URL=https://yvzjqbqklmkemstfeytz.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Canonical public origin for magic-link / OAuth redirects (no trailing slash).
# Local: http://localhost:4321
# Prod: https://digimenu.nachomallavia.workers.dev
# PUBLIC_SITE_URL=http://localhost:4321

# Ops only — never expose to the browser. Used to link owners → restaurants.
# SUPABASE_SERVICE_ROLE_KEY=

# DigiMenu owner session cookie (HMAC). Falls back to EMDASH_ENCRYPTION_KEY if unset.
# DIGIMENU_SESSION_SECRET=

# Optional: EmDash HTTP API for writes from DigiMenu BFF.
# Reads use in-process getEmDashCollection (same Astro app).
# Local:
# EMDASH_API_BASE=http://localhost:4321
# EMDASH_API_TOKEN=ec_pat_...
# Workers: set via `wrangler secret put` (EMDASH_API_BASE=https://digimenu.nachomallavia.workers.dev)
# — do not rely on baking localhost from this file into production builds.
# Existing EmDash secret
# EMDASH_ENCRYPTION_KEY=
